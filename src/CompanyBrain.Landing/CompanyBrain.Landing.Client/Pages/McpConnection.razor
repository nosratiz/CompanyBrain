@page "/mcp-connection"
@rendermode InteractiveWebAssembly
@using CompanyBrain.Landing.Client.Models
@using CompanyBrain.Landing.Client.Services
@inject ApiClient Api
@inject TokenAuthStateProvider Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>MCP Connection — CompanyBrain</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Variant="Variant.Text"
               OnClick='() => Nav.NavigateTo("/dashboard")' Class="mb-4"
               Style="color: rgba(255,255,255,0.5); text-transform: none;">
        Back to Dashboard
    </MudButton>

    <MudText Typo="Typo.h4" Class="mb-2" Style="font-weight: 800; font-family: 'Inter', sans-serif;">
        MCP Connection
    </MudText>
    <MudText Typo="Typo.body1" Class="mb-6" Style="color: rgba(255,255,255,0.45); font-family: 'Inter', sans-serif;">
        Connect your AI assistants to your knowledge base using the Model Context Protocol.
    </MudText>

    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 4rem 0;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </div>
    }
    else if (_mcpInfo is not null)
    {
        @* ── Connection Details ── *@
        <MudCard Elevation="0" Class="mb-4" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px;">
            <MudCardContent Style="padding: 2rem;">
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700; font-family: 'Inter', sans-serif;">
                    Server Details
                </MudText>
                <MudGrid Spacing="3">
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">Server URL</MudText>
                        <MudTextField Value="@_mcpInfo.ServerUrl" Variant="Variant.Outlined" ReadOnly="true"
                                      Style="font-family: monospace;" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.4);">Protocol</MudText>
                        <MudTextField Value="@_mcpInfo.Protocol" Variant="Variant.Outlined" ReadOnly="true" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>

        @* ── Supported Clients ── *@
        <MudCard Elevation="0" Class="mb-4" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px;">
            <MudCardContent Style="padding: 2rem;">
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700; font-family: 'Inter', sans-serif;">
                    Supported Clients
                </MudText>
                <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                    @foreach (var client in _mcpInfo.SupportedClients)
                    {
                        <MudChip T="string" Size="Size.Medium"
                                 Style="background: rgba(102, 126, 234, 0.15); color: #667eea; font-weight: 600; border-radius: 12px;">
                            @GetClientIcon(client) @client
                        </MudChip>
                    }
                </MudStack>
            </MudCardContent>
        </MudCard>

        @* ── Setup Instructions ── *@
        <MudCard Elevation="0" Style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 20px;">
            <MudCardContent Style="padding: 2rem;">
                <MudText Typo="Typo.subtitle1" Class="mb-3" Style="font-weight: 700; font-family: 'Inter', sans-serif;">
                    Setup Instructions
                </MudText>

                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mb-4"
                          Style="border-radius: 12px;">
                    You'll need an API key. <MudLink Href="/api-keys" Style="color: #667eea; font-weight: 600;">Create one here</MudLink>.
                </MudAlert>

                <pre style="background: #1a1a2e; border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.5rem; overflow-x: auto; font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; line-height: 1.7; white-space: pre-wrap; color: rgba(255,255,255,0.85);">@_mcpInfo.Instructions</pre>
            </MudCardContent>
        </MudCard>
    }
    else
    {
        <MudAlert Severity="Severity.Warning">Unable to load MCP connection info.</MudAlert>
    }
</MudContainer>

@code {
    private McpConnectionInfoResponse? _mcpInfo;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var state = await Auth.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login");
            return;
        }

        try
        {
            var profile = await Api.GetProfileAsync();
            if (profile is null)
            {
                Nav.NavigateTo("/login");
                return;
            }
            _mcpInfo = await Api.GetMcpConnectionInfoAsync(profile.TenantId);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await Auth.LogoutAsync();
            Nav.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetClientIcon(string client) => client switch
    {
        "Claude Desktop" => "🤖",
        "GitHub Copilot (VS Code)" => "🧑‍💻",
        "Continue.dev" => "▶️",
        "Cursor" => "📝",
        _ => "🔌"
    };
}
