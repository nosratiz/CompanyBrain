@inherits LayoutComponentBase
@using CompanyBrain.Dashboard.Features.Auth.Services
@inject AuthTokenStore TokenStore
@inject TokenAuthenticationStateProvider AuthStateProvider
@inject BrowserAuthSessionStorage SessionStorage
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (_isInitializing)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!TokenStore.IsAuthenticated && !IsLoginPage)
{
    <RedirectToLogin />
}
else
{
    <MudLayout>
        <MudAppBar Elevation="1">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
            <MudText Typo="Typo.h5" Class="ml-3">Company Brain</MudText>
            <MudSpacer />
            @if (TokenStore.IsAuthenticated)
            {
                <MudText Typo="Typo.body2" Color="Color.Inherit" Class="mr-3">@TokenStore.DisplayName</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               OnClick="Logout" />
            }
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="ToggleDarkMode" />
        </MudAppBar>
        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
            <MudNavMenu>
                @if (TokenStore.IsAuthenticated)
                {
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                    <MudNavLink Href="/documents" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Description">Documents</MudNavLink>
                    <MudNavLink Href="/search" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">Search</MudNavLink>
                    <MudNavLink Href="/import" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CloudUpload">Import</MudNavLink>
                    <MudNavLink Href="/mcp-server" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Hub">MCP Server</MudNavLink>
                }
                else
                {
                    <MudNavLink Href="/login" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
                }
            </MudNavMenu>
        </MudDrawer>
        <MudMainContent Class="pt-16 px-4">
            <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
}

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private bool _isInitializing = true;

    private bool IsLoginPage => Navigation.Uri.Contains("/login", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Enable JS interop and restore session from localStorage
            SessionStorage.EnableJsInterop();
            var restored = await TokenStore.RestoreSessionAsync();
            if (restored)
            {
                AuthStateProvider.NotifyAuthStateChanged();
            }
            _isInitializing = false;
            StateHasChanged();
        }
    }

    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976d2",
            Secondary = "#dc004e",
            AppbarBackground = "#1976d2"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#90caf9",
            Secondary = "#f48fb1",
            AppbarBackground = "#1e1e1e"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    private async Task Logout()
    {
        await TokenStore.ClearAsync();
        AuthStateProvider.NotifyAuthStateChanged();
        Navigation.NavigateTo("/login");
    }
}
