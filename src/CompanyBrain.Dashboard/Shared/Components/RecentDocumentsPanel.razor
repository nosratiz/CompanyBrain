@* Recent documents panel with a table showing the latest documents *@

<MudPaper Class="pa-4">
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">@Title</MudText>
        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="@ViewAllHref">View All</MudButton>
    </div>
    <MudTable Items="@Documents" Hover="true" Dense="true">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Size</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudLink Href="@($"/documents/{Uri.EscapeDataString(context.Name)}")">@context.Name</MudLink>
            </MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Color="@UiDisplayHelper.GetMimeTypeColor(context.MimeType)">
                    @UiDisplayHelper.GetMimeTypeLabel(context.MimeType)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Size">@FormatHelper.FormatBytes(context.Size ?? 0)</MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText>@EmptyMessage</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    [Parameter]
    public string Title { get; set; } = "Recent Documents";

    [Parameter]
    public string ViewAllHref { get; set; } = "/documents";

    [Parameter, EditorRequired]
    public IEnumerable<KnowledgeResourceDescriptor> Documents { get; set; } = [];

    [Parameter]
    public RenderFragment? EmptyMessage { get; set; }
}
