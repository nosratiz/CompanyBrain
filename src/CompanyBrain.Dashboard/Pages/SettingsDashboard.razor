@page "/settings"
@using CompanyBrain.Dashboard.Data.Models
@using CompanyBrain.Dashboard.Pages.SettingsTabs
@rendermode RenderMode.InteractiveServer
@inject SettingsService SettingsService
@inject ISnackbar Snackbar
@inject ILogger<SettingsDashboard> Logger

<PageTitle>Settings & Governance - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Settings & Governance</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Configure AI behavior, security policies, and system integrations for NexusNode.
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_settings is not null)
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Settings">
            <GeneralSettingsTab Settings="_settings" Saving="_saving" OnSave="SaveSettings" />
        </MudTabPanel>

        <MudTabPanel Text="Security" Icon="@Icons.Material.Filled.Security">
            <SecuritySettingsTab Settings="_settings" Saving="_saving" OnSave="SaveSettings" />
        </MudTabPanel>

        <MudTabPanel Text="AI Tuning" Icon="@Icons.Material.Filled.Psychology">
            <AiTuningSettingsTab Settings="_settings" Saving="_saving" OnSave="SaveSettings" />
        </MudTabPanel>

        <MudTabPanel Text="DeepRoot" Icon="@Icons.Material.Filled.Hub">
            <DeepRootSettingsTab />
        </MudTabPanel>

        <MudTabPanel Text="SharePoint" Icon="@Icons.Material.Filled.Cloud">
            <SharePointSettingsTab Settings="_settings" Saving="_saving" OnSave="SaveSettings" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    private bool _loading = true;
    private AppSettings? _settings;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await SettingsService.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load settings");
            Snackbar.Add("Failed to load settings", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveSettings()
    {
        if (_settings is null) return;

        _saving = true;
        try
        {
            await SettingsService.UpdateSettingsAsync(s =>
            {
                s.EnablePiiMasking = _settings.EnablePiiMasking;
                s.MaxStorageGb = _settings.MaxStorageGb;
                s.SecurityMode = _settings.SecurityMode;
                s.ExcludedPatterns = _settings.ExcludedPatterns;
                s.SystemPromptPrefix = _settings.SystemPromptPrefix;
                s.TenantId = _settings.TenantId;
                s.McpRequireAuth = _settings.McpRequireAuth;
                s.McpApiKey = _settings.McpApiKey;
                s.McpEnableIpWhitelist = _settings.McpEnableIpWhitelist;
                s.McpIpWhitelist = _settings.McpIpWhitelist;
                s.SharePointSyncEnabled = _settings.SharePointSyncEnabled;
                s.SharePointClientId = _settings.SharePointClientId;
                s.SharePointTenantId = _settings.SharePointTenantId;
                s.SharePointClientSecret = _settings.SharePointClientSecret;
                s.SharePointSyncIntervalMinutes = _settings.SharePointSyncIntervalMinutes;
                s.SharePointLocalBasePath = _settings.SharePointLocalBasePath;
            });

            Snackbar.Add("Settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save settings");
            Snackbar.Add("Failed to save settings", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
