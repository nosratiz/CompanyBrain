@page "/settings"
@using CompanyBrain.Dashboard.Data.Models
@attribute [Authorize]
@rendermode RenderMode.InteractiveServer
@inject SettingsService SettingsService
@inject ISnackbar Snackbar
@inject ILogger<SettingsDashboard> Logger

<PageTitle>Settings & Governance - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Settings & Governance</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Configure AI behavior, security policies, and system integrations for NexusNode.
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_settings is not null)
{
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        @* General Settings Tab *@
        <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Settings">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-primary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Storage & Limits</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudNumericField T="int" 
                                             Label="Maximum Storage (GB)" 
                                             @bind-Value="_settings.MaxStorageGb"
                                             Min="1" 
                                             Max="1000"
                                             Variant="Variant.Outlined"
                                             HelperText="Maximum storage allowed for the knowledge base"
                                             Class="mb-4" />
                            
                            <MudTextField Label="Excluded Patterns"
                                          @bind-Value="_settings.ExcludedPatterns"
                                          Variant="Variant.Outlined"
                                          Lines="3"
                                          HelperText="Semicolon-separated glob patterns to exclude (e.g., *.secret;.env;**/credentials/**)"
                                          Class="mb-4" />
                            
                            <MudTextField Label="Tenant ID"
                                          Value="@(_settings.TenantId?.ToString() ?? "Not set")"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          HelperText="Your unique tenant identifier for multi-tenant isolation" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-secondary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Claude Config Generator</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-4">
                                Generate a configuration snippet for claude_desktop_config.json.
                            </MudText>
                            <MudButton Variant="Variant.Filled" 
                                       Color="Color.Primary" 
                                       StartIcon="@Icons.Material.Filled.Code"
                                       OnClick="GenerateClaudeConfig"
                                       FullWidth="true">
                                Generate Config
                            </MudButton>
                            
                            @if (!string.IsNullOrEmpty(_generatedConfig))
                            {
                                <MudTextField @bind-Value="_generatedConfig"
                                              Variant="Variant.Outlined"
                                              Lines="10"
                                              ReadOnly="true"
                                              Class="mt-4"
                                              Style="font-family: monospace; font-size: 0.85rem;" />
                                <MudButton Variant="Variant.Text" 
                                           Color="Color.Secondary" 
                                           StartIcon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="CopyConfigToClipboard"
                                           Class="mt-2">
                                    Copy to Clipboard
                                </MudButton>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               OnClick="SaveSettings"
                               StartIcon="@Icons.Material.Filled.Save"
                               Disabled="_saving">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save Settings
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        
        @* Security Settings Tab *@
        <MudTabPanel Text="Security" Icon="@Icons.Material.Filled.Security">
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-warning">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Security Mode</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSelect T="string" 
                                       Label="Security Mode" 
                                       @bind-Value="_settings.SecurityMode"
                                       Variant="Variant.Outlined"
                                       Class="mb-4">
                                <MudSelectItem Value="@("Strict")">Strict - Full path validation and PII masking</MudSelectItem>
                                <MudSelectItem Value="@("Moderate")">Moderate - Path validation only</MudSelectItem>
                                <MudSelectItem Value="@("Relaxed")">Relaxed - Minimal security (dev only)</MudSelectItem>
                            </MudSelect>
                            
                            @if (_settings.SecurityMode == "Relaxed")
                            {
                                <MudAlert Severity="Severity.Warning" Class="mb-4">
                                    Warning: Relaxed mode disables most security checks. 
                                    Only use in trusted development environments.
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-info">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Shield" Class="mr-2" />
                                    Security Jail
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-2">Active protections:</MudText>
                            <MudList T="string" Dense="true">
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Directory traversal prevention
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Path normalization
                                </MudListItem>
                                <MudListItem Icon="@(_settings.EnablePiiMasking ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)" 
                                             IconColor="@(_settings.EnablePiiMasking ? Color.Success : Color.Default)">
                                    PII redaction (@(_settings.EnablePiiMasking ? "enabled" : "disabled"))
                                </MudListItem>
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-error">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">PII Masking</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch T="bool" 
                                       @bind-Value="_settings.EnablePiiMasking"
                                       Color="Color.Primary"
                                       Label="Enable PII Redaction" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                                When enabled, emails, API keys (sk-...), IP addresses, and tokens are redacted.
                            </MudText>
                            <MudChipSet T="string" Class="mt-2">
                                <MudChip T="string" Icon="@Icons.Material.Filled.Email" Size="Size.Small">Emails</MudChip>
                                <MudChip T="string" Icon="@Icons.Material.Filled.Key" Size="Size.Small">API Keys</MudChip>
                                <MudChip T="string" Icon="@Icons.Material.Filled.Computer" Size="Size.Small">IP Addresses</MudChip>
                                <MudChip T="string" Icon="@Icons.Material.Filled.VpnKey" Size="Size.Small">AWS Keys</MudChip>
                            </MudChipSet>
                            
                            <MudDivider Class="my-4" />
                            
                            <MudText Typo="Typo.subtitle2" Class="mb-2">Test PII Detection</MudText>
                            <MudTextField @bind-Value="_piiTestInput"
                                          Variant="Variant.Outlined"
                                          Lines="3"
                                          Placeholder="Paste text to test PII detection..."
                                          Class="mb-2" />
                            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="TestPiiDetection" Size="Size.Small">
                                Test Detection
                            </MudButton>
                            
                            @if (_piiDetectionResult is not null)
                            {
                                <MudAlert Severity="@(_piiDetectionResult.Value.HasPii ? Severity.Warning : Severity.Success)" Class="mt-2">
                                    @if (_piiDetectionResult.Value.HasPii)
                                    {
                                        @($"Found {_piiDetectionResult.Value.TotalCount} PII items ({_piiDetectionResult.Value.EmailCount} emails, {_piiDetectionResult.Value.ApiKeyCount} API keys, {_piiDetectionResult.Value.IpAddressCount} IPs)")
                                    }
                                    else
                                    {
                                        @("No PII detected in the input.")
                                    }
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                @* MCP Authorization Section *@
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-primary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.VpnLock" Class="mr-2" />
                                    MCP Access Control
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudSwitch T="bool" 
                                               Value="_settings.McpRequireAuth"
                                               ValueChanged="@(v => { _settings.McpRequireAuth = v; StateHasChanged(); })"
                                               Color="Color.Primary"
                                               Label="Require API Key Authentication" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                        When enabled, MCP clients must provide an API key to connect.
                                    </MudText>
                                    
                                    @if (_settings.McpRequireAuth)
                                    {
                                        <MudTextField @bind-Value="_settings.McpApiKey"
                                                      Label="MCP API Key"
                                                      Variant="Variant.Outlined"
                                                      InputType="@(_showApiKey ? InputType.Text : InputType.Password)"
                                                      Adornment="Adornment.End"
                                                      AdornmentIcon="@(_showApiKey ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                                      OnAdornmentClick="@(() => _showApiKey = !_showApiKey)"
                                                      HelperText="The API key clients must use to authenticate"
                                                      Class="mt-4" />
                                        <MudButton Variant="Variant.Outlined" 
                                                   Size="Size.Small" 
                                                   Color="Color.Secondary"
                                                   StartIcon="@Icons.Material.Filled.Refresh"
                                                   OnClick="GenerateApiKey"
                                                   Class="mt-2">
                                            Generate New Key
                                        </MudButton>
                                    }
                                </MudItem>
                                
                                <MudItem xs="12" md="6">
                                    <MudSwitch T="bool" 
                                               Value="_settings.McpEnableIpWhitelist"
                                               ValueChanged="@(v => { _settings.McpEnableIpWhitelist = v; StateHasChanged(); })"
                                               Color="Color.Warning"
                                               Label="Enable IP Whitelist" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                                        Restrict MCP connections to specific IP addresses.
                                    </MudText>
                                    
                                    @if (_settings.McpEnableIpWhitelist)
                                    {
                                        <MudTextField @bind-Value="_settings.McpIpWhitelist"
                                                      Label="Allowed IP Addresses"
                                                      Variant="Variant.Outlined"
                                                      Lines="4"
                                                      HelperText="Semicolon-separated IPs or CIDR ranges (e.g., 127.0.0.1;192.168.1.0/24)"
                                                      Class="mt-4" />
                                        <MudChipSet T="string" Class="mt-2">
                                            @foreach (var ip in GetWhitelistedIps())
                                            {
                                                <MudChip T="string" Icon="@Icons.Material.Filled.Computer" Size="Size.Small">@ip</MudChip>
                                            }
                                        </MudChipSet>
                                    }
                                </MudItem>
                                
                                <MudItem xs="12">
                                    @if (_settings.McpRequireAuth || _settings.McpEnableIpWhitelist)
                                    {
                                        <MudAlert Severity="Severity.Info" Class="mt-2">
                                            <strong>MCP Access Configuration:</strong>
                                            <ul class="mb-0">
                                                @if (_settings.McpRequireAuth)
                                                {
                                                    <li>API key authentication is required</li>
                                                }
                                                @if (_settings.McpEnableIpWhitelist)
                                                {
                                                    <li>IP whitelist is active (@GetWhitelistedIps().Count() addresses allowed)</li>
                                                }
                                            </ul>
                                        </MudAlert>
                                    }
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save Settings
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        
        @* AI Tuning Tab *@
        <MudTabPanel Text="AI Tuning" Icon="@Icons.Material.Filled.Psychology">
            <MudGrid>
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-tertiary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">System Prompt Prefix</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                                This prefix will be prepended to every AI resource request. Use it for governance instructions.
                            </MudText>
                            
                            <MudTextField @bind-Value="_settings.SystemPromptPrefix"
                                          Variant="Variant.Outlined"
                                          Lines="6"
                                          Placeholder="Example: You are operating in a secure corporate environment..."
                                          Class="mb-4" />
                            
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @(_settings.SystemPromptPrefix.Length) / 4000 characters
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-default">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Prompt Templates</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-2">Quick templates:</MudText>
                            <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" OverrideStyles="false">
                                <MudButton OnClick="@(() => ApplyTemplate("security"))">Security Focus</MudButton>
                                <MudButton OnClick="@(() => ApplyTemplate("governance"))">Governance</MudButton>
                                <MudButton OnClick="@(() => ApplyTemplate("minimal"))">Minimal</MudButton>
                            </MudButtonGroup>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="6">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-default">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Preview</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-2">How your prefix will appear:</MudText>
                            <MudPaper Elevation="0" Class="pa-3 mud-background-gray" Style="font-family: monospace; font-size: 0.85rem; white-space: pre-wrap;">
                                @if (!string.IsNullOrWhiteSpace(_settings.SystemPromptPrefix))
                                {
                                    @_settings.SystemPromptPrefix
                                    <br /><br />
                                    @("[Resource Content Here]")
                                }
                                else
                                {
                                    <span style="color: gray;">[No prefix configured]</span>
                                    <br /><br />
                                    @("[Resource Content Here]")
                                }
                            </MudPaper>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveSettings" StartIcon="@Icons.Material.Filled.Save" Disabled="_saving">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save Settings
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudTabPanel>
        
        @* SharePoint Integration Tab *@
        <MudTabPanel Text="SharePoint" Icon="@Icons.Material.Filled.Cloud">
            <MudGrid>
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info" Class="mb-4">
                        Configure Azure AD credentials to enable SharePoint document synchronization. 
                        Documents from SharePoint will be automatically synced to your local knowledge base.
                    </MudAlert>
                </MudItem>
                
                <MudItem xs="12" md="8">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-primary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
                                    Azure AD Configuration
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSwitch T="bool" 
                                       @bind-Value="_settings.SharePointSyncEnabled"
                                       Color="Color.Primary"
                                       Label="Enable SharePoint Sync" 
                                       Class="mb-4" />
                            
                            <MudTextField Label="Client ID (Application ID)"
                                          @bind-Value="_settings.SharePointClientId"
                                          Variant="Variant.Outlined"
                                          Placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                          HelperText="The Application (client) ID from your Azure AD app registration"
                                          Disabled="@(!_settings.SharePointSyncEnabled)"
                                          Class="mb-4" />
                            
                            <MudTextField Label="Tenant ID"
                                          @bind-Value="_settings.SharePointTenantId"
                                          Variant="Variant.Outlined"
                                          Placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                          HelperText="The Directory (tenant) ID from Azure AD"
                                          Disabled="@(!_settings.SharePointSyncEnabled)"
                                          Class="mb-4" />
                            
                            <MudTextField Label="Client Secret"
                                          @bind-Value="_settings.SharePointClientSecret"
                                          Variant="Variant.Outlined"
                                          InputType="@(_showSharePointSecret ? InputType.Text : InputType.Password)"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(_showSharePointSecret ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                                          OnAdornmentClick="@(() => _showSharePointSecret = !_showSharePointSecret)"
                                          HelperText="The client secret from your Azure AD app registration"
                                          Disabled="@(!_settings.SharePointSyncEnabled)"
                                          Class="mb-4" />
                            
                            @if (_settings.SharePointSyncEnabled && string.IsNullOrWhiteSpace(_settings.SharePointClientSecret))
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
                                    Client secret is required for SharePoint sync to work.
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12" md="4">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-secondary">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">Required Permissions</MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Class="mb-2">
                                Your Azure AD app needs these Microsoft Graph API permissions:
                            </MudText>
                            <MudList T="string" Dense="true">
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Sites.Read.All
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    Files.Read.All
                                </MudListItem>
                                <MudListItem Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                    offline_access
                                </MudListItem>
                            </MudList>
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Grant admin consent after adding these permissions.
                            </MudText>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudCard Elevation="0" Class="border-1 border-solid mud-border-default">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.h6">
                                    <MudIcon Icon="@Icons.Material.Filled.Sync" Class="mr-2" />
                                    Sync Settings
                                </MudText>
                            </CardHeaderContent>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" md="6">
                                    <MudNumericField T="int" 
                                                     Label="Sync Interval (minutes)" 
                                                     @bind-Value="_settings.SharePointSyncIntervalMinutes"
                                                     Min="5" 
                                                     Max="1440"
                                                     Variant="Variant.Outlined"
                                                     HelperText="How often to check for new or updated documents (5-1440 min)"
                                                     Disabled="@(!_settings.SharePointSyncEnabled)" />
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField Label="Local Sync Folder"
                                                  @bind-Value="_settings.SharePointLocalBasePath"
                                                  Variant="Variant.Outlined"
                                                  Placeholder="@GetDefaultSharePointPath()"
                                                  HelperText="Local folder to store synced SharePoint documents"
                                                  Disabled="@(!_settings.SharePointSyncEnabled)" />
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
                
                <MudItem xs="12">
                    <MudButton Variant="Variant.Filled" 
                               Color="Color.Primary" 
                               OnClick="SaveSettings" 
                               StartIcon="@Icons.Material.Filled.Save" 
                               Disabled="_saving"
                               Class="mr-2">
                        @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                        Save Settings
                    </MudButton>
                    
                    @if (_settings.SharePointSyncEnabled && !string.IsNullOrWhiteSpace(_settings.SharePointClientId))
                    {
                        <MudButton Variant="Variant.Outlined" 
                                   Color="Color.Secondary" 
                                   OnClick="TestSharePointConnection" 
                                   StartIcon="@Icons.Material.Filled.NetworkCheck"
                                   Disabled="_testingConnection">
                            @if (_testingConnection) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Test Connection
                        </MudButton>
                    }
                </MudItem>
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private bool _loading = true;
    private AppSettings? _settings;
    private bool _saving;
    private string? _generatedConfig;
    private string? _piiTestInput;
    private PiiDetectionResult? _piiDetectionResult;
    private bool _showApiKey;
    private bool _showSharePointSecret;
    private bool _testingConnection;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _settings = await SettingsService.GetSettingsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load settings");
            Snackbar.Add("Failed to load settings", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveSettings()
    {
        if (_settings is null) return;
        
        _saving = true;
        try
        {
            await SettingsService.UpdateSettingsAsync(s =>
            {
                s.EnablePiiMasking = _settings.EnablePiiMasking;
                s.MaxStorageGb = _settings.MaxStorageGb;
                s.SecurityMode = _settings.SecurityMode;
                s.ExcludedPatterns = _settings.ExcludedPatterns;
                s.SystemPromptPrefix = _settings.SystemPromptPrefix;
                s.TenantId = _settings.TenantId;
                s.McpRequireAuth = _settings.McpRequireAuth;
                s.McpApiKey = _settings.McpApiKey;
                s.McpEnableIpWhitelist = _settings.McpEnableIpWhitelist;
                s.McpIpWhitelist = _settings.McpIpWhitelist;
                
                // SharePoint settings
                s.SharePointSyncEnabled = _settings.SharePointSyncEnabled;
                s.SharePointClientId = _settings.SharePointClientId;
                s.SharePointTenantId = _settings.SharePointTenantId;
                s.SharePointClientSecret = _settings.SharePointClientSecret;
                s.SharePointSyncIntervalMinutes = _settings.SharePointSyncIntervalMinutes;
                s.SharePointLocalBasePath = _settings.SharePointLocalBasePath;
            });
            
            Snackbar.Add("Settings saved successfully", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save settings");
            Snackbar.Add("Failed to save settings", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void GenerateClaudeConfig()
    {
        var tenantId = _settings?.TenantId?.ToString() ?? "your-tenant-id";
        var exePath = GetExecutablePath();
        
        _generatedConfig = $$"""
{
  "mcpServers": {
    "company-brain": {
      "command": "{{exePath}}",
      "args": [],
      "env": {
        "TENANT_ID": "{{tenantId}}"
      }
    }
  }
}
""";
    }

    private IEnumerable<string> GetWhitelistedIps()
    {
        if (string.IsNullOrWhiteSpace(_settings?.McpIpWhitelist))
            return [];
        
        return _settings.McpIpWhitelist
            .Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(ip => !string.IsNullOrWhiteSpace(ip));
    }

    private void GenerateApiKey()
    {
        if (_settings is null) return;
        
        // Generate a secure random API key
        var keyBytes = new byte[32];
        System.Security.Cryptography.RandomNumberGenerator.Fill(keyBytes);
        _settings.McpApiKey = $"cb_{Convert.ToBase64String(keyBytes).Replace("+", "-").Replace("/", "_").TrimEnd('=')}";
        StateHasChanged();
    }

    private string GetExecutablePath()
    {
        var baseDir = AppContext.BaseDirectory;
        var exeName = OperatingSystem.IsWindows() ? "CompanyBrain.Dashboard.exe" : "CompanyBrain.Dashboard";
        return Path.Combine(baseDir, exeName).Replace("\\", "\\\\");
    }

    private void CopyConfigToClipboard()
    {
        if (_generatedConfig is null) return;
        Snackbar.Add("Config ready to copy. Use Ctrl+C on the text field.", Severity.Info);
    }

    private void TestPiiDetection()
    {
        if (string.IsNullOrWhiteSpace(_piiTestInput))
        {
            _piiDetectionResult = null;
            return;
        }
        _piiDetectionResult = SecurityHelpers.DetectPii(_piiTestInput);
    }

    private void ApplyTemplate(string templateName)
    {
        if (_settings is null) return;
        
        _settings.SystemPromptPrefix = templateName switch
        {
            "security" => """
                SECURITY CONTEXT: You are operating within a secure, sandboxed environment.
                - Always validate file paths before access
                - Never expose API keys, tokens, or credentials
                - Report any suspicious patterns to the administrator
                - Prefer read-only operations unless explicitly authorized
                """,
            "governance" => """
                GOVERNANCE POLICY: Follow corporate data handling guidelines.
                - Classify all data before processing
                - Do not store PII without explicit consent
                - Log all significant operations for audit
                - Escalate policy violations immediately
                """,
            "minimal" => "",
            _ => _settings.SystemPromptPrefix
        };
        
        StateHasChanged();
    }

    private string GetDefaultSharePointPath()
    {
        return OperatingSystem.IsWindows()
            ? @"C:\NexusData\SharePoint"
            : Path.Combine(Environment.GetFolderPath(Environment.SpecialFolder.UserProfile), "NexusData", "SharePoint");
    }

    private async Task TestSharePointConnection()
    {
        if (_settings is null) return;
        
        _testingConnection = true;
        StateHasChanged();
        
        try
        {
            // Validate required fields
            if (string.IsNullOrWhiteSpace(_settings.SharePointClientId) ||
                string.IsNullOrWhiteSpace(_settings.SharePointTenantId) ||
                string.IsNullOrWhiteSpace(_settings.SharePointClientSecret))
            {
                Snackbar.Add("Please fill in all Azure AD credentials", Severity.Warning);
                return;
            }

            // Basic GUID validation
            if (!Guid.TryParse(_settings.SharePointClientId, out _))
            {
                Snackbar.Add("Client ID must be a valid GUID", Severity.Error);
                return;
            }
            
            if (!Guid.TryParse(_settings.SharePointTenantId, out _))
            {
                Snackbar.Add("Tenant ID must be a valid GUID", Severity.Error);
                return;
            }

            // For now, just validate the format. 
            // A full connection test would require the SharePointSyncService.
            Snackbar.Add("Configuration format is valid. Save settings to apply changes.", Severity.Success);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "SharePoint connection test failed");
            Snackbar.Add($"Connection test failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _testingConnection = false;
            StateHasChanged();
        }
    }
}
