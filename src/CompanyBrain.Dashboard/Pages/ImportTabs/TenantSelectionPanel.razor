@inject ExternalTenantApiClient ExternalTenantApi
@inject ISnackbar Snackbar

<MudExpansionPanels Class="mb-4">
    <MudExpansionPanel Text="Tenant Access Settings" Icon="@Icons.Material.Filled.Business" @bind-Expanded="_expanded">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Select which tenants can access imported documents. Leave empty to make documents available to everyone.
        </MudText>
        
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_availableTenants.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No tenants configured. All imported documents will be available to everyone.
            </MudAlert>
        }
        else
        {
            <MudPaper Outlined="true" Class="pa-3 mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Color="Color.Info">
                        @if (SelectedTenantIds.Count == 0)
                        {
                            <span><strong>Public Documents</strong> - All tenants can access imported documents</span>
                        }
                        else
                        {
                            <span><strong>Restricted Access</strong> - Only @(SelectedTenantIds.Count) tenant(s) can access imported documents</span>
                        }
                    </MudText>
                </MudStack>
            </MudPaper>

            <MudSelect T="Guid"
                       Label="Select Tenants"
                       MultiSelection="true"
                       @bind-SelectedValues="BoundSelectedTenantIds"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Dense="true"
                       Class="mb-2">
                @foreach (var tenant in _availableTenants)
                {
                    <MudSelectItem T="Guid" Value="@tenant.Id">
                        @tenant.Name (@tenant.PlanName)
                    </MudSelectItem>
                }
            </MudSelect>

            @if (SelectedTenantIds.Count > 0)
            {
                <MudChipSet T="Guid" Class="mt-2">
                    @foreach (var tenantId in SelectedTenantIds)
                    {
                        var tenant = _availableTenants.FirstOrDefault(t => t.Id == tenantId);
                        if (tenant is not null)
                        {
                            <MudChip T="Guid" 
                                     Value="tenantId"
                                     Color="Color.Primary"
                                     Size="Size.Small"
                                     OnClose="() => RemoveTenant(tenantId)">
                                @tenant.Name
                            </MudChip>
                        }
                    }
                </MudChipSet>
            }
        }
    </MudExpansionPanel>
</MudExpansionPanels>

@code {
    [Parameter] public HashSet<Guid> SelectedTenantIds { get; set; } = [];
    [Parameter] public EventCallback<HashSet<Guid>> SelectedTenantIdsChanged { get; set; }
    
    private bool _expanded;
    private bool _loading = true;
    private List<TenantSummaryDto> _availableTenants = [];

    private IEnumerable<Guid> BoundSelectedTenantIds
    {
        get => SelectedTenantIds;
        set
        {
            SelectedTenantIds = value.ToHashSet();
            SelectedTenantIdsChanged.InvokeAsync(SelectedTenantIds);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _loading = true;
        try
        {
            var tenants = await ExternalTenantApi.GetTenantsAsync();
            _availableTenants = tenants.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load tenants: {ex.Message}", Severity.Warning);
            _availableTenants = [];
        }
        finally
        {
            _loading = false;
        }
    }

    private void RemoveTenant(Guid tenantId)
    {
        SelectedTenantIds.Remove(tenantId);
        SelectedTenantIdsChanged.InvokeAsync(SelectedTenantIds);
    }

    /// <summary>
    /// Gets tenant assignments for the currently selected tenants.
    /// </summary>
    public List<TenantAssignment> GetTenantAssignments()
    {
        return SelectedTenantIds
            .Select(id =>
            {
                var tenant = _availableTenants.FirstOrDefault(t => t.Id == id);
                return new TenantAssignment(id, tenant?.Name ?? "Unknown");
            })
            .ToList();
    }
}
