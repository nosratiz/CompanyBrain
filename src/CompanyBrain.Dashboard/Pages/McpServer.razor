@page "/mcp-server"
@using CompanyBrain.Dashboard.Pages.McpServerComponents
@inject McpStatusClient McpClient
@inject NavigationManager Navigation

<PageTitle>MCP Server - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">MCP Server</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}

<MudGrid Class="mb-4">
    <MudItem xs="12" md="6">
        <McpStatusCard Status="_status" Loading="_loading" OnRefresh="RefreshStatus" />
    </MudItem>
    <MudItem xs="12" md="6">
        <McpEndpointCard EndpointUrl="@McpEndpointUrl" />
    </MudItem>
</MudGrid>

@if (_status.IsRunning)
{
    <McpToolTester Tool="_selectedTool" OnClose="CloseToolTester" />

    <McpToolsTable Tools="_status.Tools" OnTestTool="OpenToolTester" />

    <McpResourcesTable Resources="_status.Resources" OnResourceDeleted="RefreshStatus" />

    <McpConfigSnippet EndpointUrl="@McpEndpointUrl" />
}

@code {
    private McpServerStatus _status = new();
    private bool _loading = true;
    private McpToolInfo? _selectedTool;

    private string McpEndpointUrl => $"{Navigation.BaseUri.TrimEnd('/')}/mcp";

    protected override async Task OnInitializedAsync()
    {
        await RefreshStatus();
    }

    private async Task RefreshStatus()
    {
        _loading = true;
        StateHasChanged();

        _status = await McpClient.GetStatusAsync();

        _loading = false;
    }

    private void OpenToolTester(McpToolInfo tool)
    {
        _selectedTool = tool;
    }

    private void CloseToolTester()
    {
        _selectedTool = null;
    }
}
