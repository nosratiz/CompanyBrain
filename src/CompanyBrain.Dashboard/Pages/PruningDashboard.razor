@page "/pruning-insights"
@using CompanyBrain.Dashboard.Data
@using System.Text.Json
@inject PruningStateContainer PruningState
@inject IDbContextFactory<DocumentAssignmentDbContext> DbFactory
@implements IDisposable

<PageTitle>Pruning Insights - Deep Root</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Pruning Insights</MudText>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_events.Count > 0)
        {
            <MudButton Variant="Variant.Outlined"
                       Size="Size.Small"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="ResetSession">
                Reset Session
            </MudButton>
        }
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.BugReport"
                   OnClick="SimulatePruningEvent">
            Simulate Event
        </MudButton>
    </MudStack>
</MudStack>

<MudGrid>
    @* Left column: Controls + Processing *@
    <MudItem xs="12" lg="4">
        <MudStack Spacing="3">
            <PruningControlCenter State="PruningState" />
            <ProcessingVisualizer State="PruningState" />
        </MudStack>
    </MudItem>

    @* Right column: Snippets + Metrics *@
    <MudItem xs="12" lg="8">
        <MudStack Spacing="3">
            <SavingsMetrics State="PruningState" Events="_events" />
            <SnippetBrowser Events="_events" />
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private IReadOnlyList<PruningEvent> _events = [];
    private int _lastSyncedDbId;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        PruningState.OnChange += HandleStateChange;
        await SyncFromDbAsync();

        _pollCts = new CancellationTokenSource();
        _ = PollDbAsync(_pollCts.Token);
    }

    private void HandleStateChange()
    {
        // In HTTP mode: GovernanceToolWrapper writes to DB first, then calls NotifyEventRecorded.
        // Trigger an immediate DB sync so the UI reflects the new event without waiting for the timer.
        InvokeAsync(async () =>
        {
            await SyncFromDbAsync();
            StateHasChanged();
        });
    }

    /// <summary>
    /// Loads any DB records newer than the last seen Id.
    /// Safe to call from any thread via InvokeAsync.
    /// </summary>
    private async Task SyncFromDbAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var records = await db.PruningEventRecords
            .OrderByDescending(r => r.Id)
            .Take(20)
            .ToListAsync();

        if (records.Count == 0 || records[0].Id <= _lastSyncedDbId)
            return;

        _events = records.Select(ToEvent).ToList();  // newest first
        _lastSyncedDbId = records[0].Id;
    }

    private async Task PollDbAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(async () =>
                {
                    await SyncFromDbAsync();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { /* expected on dispose */ }
    }

    private static PruningEvent ToEvent(PruningEventRecord r) => new()
    {
        ToolName          = r.ToolName,
        Query             = r.Query,
        SourceAttribution = r.SourceAttribution,
        Timestamp         = DateTimeOffset.FromUnixTimeMilliseconds(r.TimestampUnixMs),
        OriginalTokens    = r.OriginalTokens,
        PrunedTokens      = r.PrunedTokens,
        ChunksEvaluated   = r.ChunksEvaluated,
        ChunksSelected    = r.ChunksSelected,
        WasPruned         = r.WasPruned,
        PiiDetected       = r.PiiDetected,
        Snippets          = JsonSerializer.Deserialize<List<SnippetDetail>>(r.SnippetsJson) ?? []
    };

    private async Task ResetSession()
    {
        // Delete all persisted records
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.PruningEventRecords.ExecuteDeleteAsync();

        PruningState.Reset();
        _events = [];
        _lastSyncedDbId = 0;
    }

    private async Task SimulatePruningEvent()
    {
        PruningState.NotifyProcessingStarted("How do I deploy to Azure?");
        StateHasChanged();
        await Task.Delay(600);

        PruningState.NotifyPhaseChanged(ProcessingPhase.PiiMasking);
        StateHasChanged();
        await Task.Delay(500);

        PruningState.NotifyPhaseChanged(ProcessingPhase.BudgetSelection);
        StateHasChanged();
        await Task.Delay(400);

        var simulatedEvent = new PruningEvent
        {
            ToolName = "SearchDocs",
            Query = "How do I deploy to Azure?",
            SourceAttribution = "InternalKnowledge",
            Timestamp = DateTimeOffset.Now,
            OriginalTokens = 4200,
            PrunedTokens = 1100,
            ChunksEvaluated = 12,
            ChunksSelected = 3,
            WasPruned = true,
            PiiDetected = true,
            Snippets =
            [
                new SnippetDetail
                {
                    Text = "To deploy to Azure, use the Azure CLI: az webapp deploy --resource-group myRG --name myApp. Contact admin@company.com for access.",
                    RedactedText = "To deploy to Azure, use the Azure CLI: az webapp deploy --resource-group myRG --name myApp. Contact [REDACTED_EMAIL] for access.",
                    SimilarityScore = 0.87,
                    Index = 2,
                    Source = "SharePoint: Azure_Deployment_Guide.md"
                },
                new SnippetDetail
                {
                    Text = "The CI/CD pipeline triggers on main branch pushes. API key: sk-proj-abc123. Set AZURE_SUBSCRIPTION_ID in your environment.",
                    RedactedText = "The CI/CD pipeline triggers on main branch pushes. API key: [REDACTED_API_KEY]. Set AZURE_SUBSCRIPTION_ID in your environment.",
                    SimilarityScore = 0.62,
                    Index = 5,
                    Source = "InternalKnowledge: cicd_guide.md"
                },
                new SnippetDetail
                {
                    Text = "For production deployments, ensure health checks pass at /health. The deployment slot swap takes approximately 30 seconds.",
                    RedactedText = "For production deployments, ensure health checks pass at /health. The deployment slot swap takes approximately 30 seconds.",
                    SimilarityScore = 0.44,
                    Index = 8,
                    Source = "InternalKnowledge: production_checklist.md"
                }
            ]
        };

        PruningState.NotifyEventRecorded(simulatedEvent);

        // Persist to DB so the event survives across page navigations and shows on the next poll.
        await using var db = await DbFactory.CreateDbContextAsync();
        db.PruningEventRecords.Add(new PruningEventRecord
        {
            ToolName          = simulatedEvent.ToolName,
            Query             = simulatedEvent.Query,
            SourceAttribution = simulatedEvent.SourceAttribution,
            TimestampUnixMs   = simulatedEvent.Timestamp.ToUnixTimeMilliseconds(),
            OriginalTokens    = simulatedEvent.OriginalTokens,
            PrunedTokens      = simulatedEvent.PrunedTokens,
            ChunksEvaluated   = simulatedEvent.ChunksEvaluated,
            ChunksSelected    = simulatedEvent.ChunksSelected,
            WasPruned         = simulatedEvent.WasPruned,
            PiiDetected       = simulatedEvent.PiiDetected,
            SnippetsJson      = JsonSerializer.Serialize(simulatedEvent.Snippets)
        });
        await db.SaveChangesAsync();
        await SyncFromDbAsync();
        StateHasChanged();
    }

    public void Dispose()
    {
        PruningState.OnChange -= HandleStateChange;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
