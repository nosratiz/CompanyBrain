@page "/pruning-insights"
@using CompanyBrain.Dashboard.Pages.PruningInsights
@inject PruningStateContainer PruningState
@implements IDisposable

<PageTitle>Pruning Insights - Deep Root</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudText Typo="Typo.h4">Pruning Insights</MudText>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (PruningState.Session.TotalCallsRecorded > 0)
        {
            <MudButton Variant="Variant.Outlined"
                       Size="Size.Small"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.RestartAlt"
                       OnClick="ResetSession">
                Reset Session
            </MudButton>
        }
        <MudButton Variant="Variant.Outlined"
                   Size="Size.Small"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.BugReport"
                   OnClick="SimulatePruningEvent">
            Simulate Event
        </MudButton>
    </MudStack>
</MudStack>

<MudGrid>
    @* Left column: Controls + Processing *@
    <MudItem xs="12" lg="4">
        <MudStack Spacing="3">
            <PruningControlCenter State="PruningState" />
            <ProcessingVisualizer State="PruningState" />
        </MudStack>
    </MudItem>

    @* Right column: Snippets + Metrics *@
    <MudItem xs="12" lg="8">
        <MudStack Spacing="3">
            <SavingsMetrics State="PruningState" />
            <SnippetBrowser Events="_events" />
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private IReadOnlyList<PruningEvent> _events = [];

    protected override void OnInitialized()
    {
        PruningState.OnChange += HandleStateChange;
        RefreshEvents();
    }

    private void HandleStateChange()
    {
        InvokeAsync(() =>
        {
            RefreshEvents();
            StateHasChanged();
        });
    }

    private void RefreshEvents()
    {
        _events = PruningState.Session.GetRecentEvents();
    }

    private void ResetSession()
    {
        PruningState.Reset();
    }

    private async Task SimulatePruningEvent()
    {
        PruningState.NotifyProcessingStarted("How do I deploy to Azure?");
        StateHasChanged();
        await Task.Delay(600);

        PruningState.NotifyPhaseChanged(ProcessingPhase.PiiMasking);
        StateHasChanged();
        await Task.Delay(500);

        PruningState.NotifyPhaseChanged(ProcessingPhase.BudgetSelection);
        StateHasChanged();
        await Task.Delay(400);

        var simulatedEvent = new PruningEvent
        {
            ToolName = "SearchDocs",
            Query = "How do I deploy to Azure?",
            SourceAttribution = "InternalKnowledge",
            Timestamp = DateTimeOffset.Now,
            OriginalTokens = 4200,
            PrunedTokens = 1100,
            ChunksEvaluated = 12,
            ChunksSelected = 3,
            WasPruned = true,
            PiiDetected = true,
            Snippets =
            [
                new SnippetDetail
                {
                    Text = "To deploy to Azure, use the Azure CLI: az webapp deploy --resource-group myRG --name myApp. Contact admin@company.com for access.",
                    RedactedText = "To deploy to Azure, use the Azure CLI: az webapp deploy --resource-group myRG --name myApp. Contact [REDACTED_EMAIL] for access.",
                    SimilarityScore = 0.87,
                    Index = 2,
                    Source = "SharePoint: Azure_Deployment_Guide.md"
                },
                new SnippetDetail
                {
                    Text = "The CI/CD pipeline triggers on main branch pushes. API key: sk-proj-abc123. Set AZURE_SUBSCRIPTION_ID in your environment.",
                    RedactedText = "The CI/CD pipeline triggers on main branch pushes. API key: [REDACTED_API_KEY]. Set AZURE_SUBSCRIPTION_ID in your environment.",
                    SimilarityScore = 0.62,
                    Index = 5,
                    Source = "InternalKnowledge: cicd_guide.md"
                },
                new SnippetDetail
                {
                    Text = "For production deployments, ensure health checks pass at /health. The deployment slot swap takes approximately 30 seconds.",
                    RedactedText = "For production deployments, ensure health checks pass at /health. The deployment slot swap takes approximately 30 seconds.",
                    SimilarityScore = 0.44,
                    Index = 8,
                    Source = "InternalKnowledge: production_checklist.md"
                }
            ]
        };

        PruningState.NotifyEventRecorded(simulatedEvent);
    }

    public void Dispose()
    {
        PruningState.OnChange -= HandleStateChange;
    }
}
