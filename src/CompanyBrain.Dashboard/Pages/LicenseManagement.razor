@page "/licenses"
@page "/licenses/{TenantId:guid}"
@inject TenantApiClient Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>License Management - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">License Management</MudText>
<MudText Typo="Typo.body1" Class="mb-4">
    Generate and manage API keys for Claude Desktop, GitHub Copilot, and other MCP-compatible clients.
</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12">
            <MudPaper Class="pa-4">
                <div class="d-flex justify-space-between align-center mb-4">
                    <MudText Typo="Typo.h6">API Keys</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="OpenCreateKeyDialog">
                        Create New Key
                    </MudButton>
                </div>

                @if (_newKey is not null)
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="() => _newKey = null">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            <strong>New API Key Created - Copy it now!</strong>
                        </MudText>
                        <MudText Typo="Typo.body2" Class="mb-2">
                            This key will only be shown once. Store it securely.
                        </MudText>
                        <div class="api-key-display d-flex align-center">
                            <MudText Typo="Typo.body2" Class="flex-grow-1" Style="font-family: monospace;">
                                @_newKey.PlainKey
                            </MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="@(() => CopyToClipboard(_newKey.PlainKey))"
                                           Size="Size.Small" />
                        </div>
                    </MudAlert>
                }

                <MudTable Items="_apiKeys" Hover="true" Striped="true" Loading="_tableLoading">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Key Prefix</MudTh>
                        <MudTh>Scope</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Last Used</MudTh>
                        <MudTh>Expires</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="Key Prefix">
                            <code>@context.KeyPrefix...</code>
                        </MudTd>
                        <MudTd DataLabel="Scope">
                            <MudChip T="string" Size="Size.Small" Color="@GetScopeColor(context.Scope)">
                                @context.Scope
                            </MudChip>
                        </MudTd>
                        <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("g")</MudTd>
                        <MudTd DataLabel="Last Used">
                            @(context.LastUsedAt?.ToLocalTime().ToString("g") ?? "Never")
                        </MudTd>
                        <MudTd DataLabel="Expires">
                            @if (context.ExpiresAt.HasValue)
                            {
                                <MudText Color="@(context.ExpiresAt < DateTime.UtcNow ? Color.Error : Color.Default)">
                                    @context.ExpiresAt.Value.ToLocalTime().ToString("d")
                                </MudText>
                            }
                            else
                            {
                                <MudText Color="Color.Default">Never</MudText>
                            }
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Size="Size.Small"
                                           OnClick="@(() => RegenerateKey(context.Id))"
                                           Title="Regenerate Key" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           OnClick="@(() => RevokeKey(context.Id, context.Name))"
                                           Title="Revoke Key" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText>No API keys found. Create one to get started.</MudText>
                    </NoRecordsContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

<!-- Create Key Dialog -->
<MudDialog @bind-Visible="_showCreateDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-2" />
            Create API Key
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_createForm">
            <MudTextField @bind-Value="_createKeyName"
                          Label="Key Name"
                          Required="true"
                          RequiredError="Name is required"
                          Placeholder="e.g., Claude Desktop - Work Laptop" />
            <MudSelect @bind-Value="_createKeyScope" Label="Scope" Class="mt-4">
                <MudSelectItem Value="@("ReadOnly")">Read Only</MudSelectItem>
                <MudSelectItem Value="@("WriteDocuments")">Write Documents</MudSelectItem>
                <MudSelectItem Value="@("ManageResources")">Manage Resources</MudSelectItem>
                <MudSelectItem Value="@("Admin")">Admin (Full Access)</MudSelectItem>
            </MudSelect>
            <MudDatePicker @bind-Date="_createKeyExpiry"
                           Label="Expiration Date (Optional)"
                           Class="mt-4"
                           Clearable="true"
                           MinDate="DateTime.Today.AddDays(1)" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="CreateKey">Create</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid TenantId { get; set; }

    private bool _loading = true;
    private bool _tableLoading = false;
    private List<ApiKeyResponse> _apiKeys = [];
    private ApiKeyCreatedResponse? _newKey;

    // Create dialog state
    private bool _showCreateDialog = false;
    private MudForm? _createForm;
    private string _createKeyName = "";
    private string _createKeyScope = "ReadOnly";
    private DateTime? _createKeyExpiry;

    protected override async Task OnInitializedAsync()
    {
        // TODO: Get from route or auth context
        if (TenantId == Guid.Empty)
        {
            var tenants = await Api.ListTenantsAsync();
            TenantId = tenants?.Tenants.FirstOrDefault()?.Id ?? Guid.Empty;
        }

        await LoadApiKeys();
        _loading = false;
    }

    private async Task LoadApiKeys()
    {
        _tableLoading = true;
        try
        {
            var response = await Api.ListApiKeysAsync(TenantId);
            _apiKeys = response?.ApiKeys.ToList() ?? [];
        }
        finally
        {
            _tableLoading = false;
        }
    }

    private void OpenCreateKeyDialog()
    {
        _createKeyName = "";
        _createKeyScope = "ReadOnly";
        _createKeyExpiry = null;
        _showCreateDialog = true;
    }

    private async Task CreateKey()
    {
        if (_createForm is not null)
        {
            await _createForm.Validate();
            if (!_createForm.IsValid) return;
        }

        try
        {
            _newKey = await Api.CreateApiKeyAsync(TenantId, new CreateApiKeyRequest(
                _createKeyName,
                _createKeyScope,
                _createKeyExpiry?.ToUniversalTime()));

            _showCreateDialog = false;
            Snackbar.Add("API key created successfully!", Severity.Success);
            await LoadApiKeys();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create key: {ex.Message}", Severity.Error);
        }
    }

    private async Task RegenerateKey(Guid keyId)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Regenerate API Key",
            "This will revoke the current key and generate a new one. Any applications using the old key will stop working. Continue?",
            yesText: "Regenerate",
            cancelText: "Cancel");

        if (confirm != true) return;

        try
        {
            _newKey = await Api.RegenerateApiKeyAsync(TenantId, keyId);
            Snackbar.Add("API key regenerated!", Severity.Success);
            await LoadApiKeys();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to regenerate key: {ex.Message}", Severity.Error);
        }
    }

    private async Task RevokeKey(Guid keyId, string keyName)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Revoke API Key",
            $"Are you sure you want to revoke '{keyName}'? This action cannot be undone.",
            yesText: "Revoke",
            cancelText: "Cancel");

        if (confirm != true) return;

        try
        {
            await Api.RevokeApiKeyAsync(TenantId, keyId);
            Snackbar.Add("API key revoked.", Severity.Info);
            await LoadApiKeys();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to revoke key: {ex.Message}", Severity.Error);
        }
    }

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        Snackbar.Add("Copied to clipboard!", Severity.Success);
    }

    private static Color GetScopeColor(string scope) => scope switch
    {
        "ReadOnly" => Color.Default,
        "WriteDocuments" => Color.Info,
        "ManageResources" => Color.Warning,
        "Admin" => Color.Error,
        _ => Color.Default
    };
}
