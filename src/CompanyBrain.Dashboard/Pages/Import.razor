@page "/import"

<PageTitle>Import - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Import Documents</MudText>

<TenantSelectionPanel @ref="_tenantPanel" @bind-SelectedTenantIds="_selectedTenantIds" />

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Wiki URL" Icon="@Icons.Material.Filled.Link">
        <WikiUrlImportTab @bind-Importing="_importing"
                          GetTenantAssignments="GetTenantAssignments"
                          OnImportSuccess="OnImportSuccess"
                          OnImportError="OnImportError" />
    </MudTabPanel>

    <MudTabPanel Text="Batch Import" Icon="@Icons.Material.Filled.PlaylistAdd">
        <BatchImportTab @bind-Importing="_importing"
                        GetTenantAssignments="GetTenantAssignments" />
    </MudTabPanel>

    <MudTabPanel Text="File Path" Icon="@Icons.Material.Filled.FolderOpen">
        <FilePathImportTab @bind-Importing="_importing"
                           GetTenantAssignments="GetTenantAssignments"
                           OnImportSuccess="OnImportSuccess"
                           OnImportError="OnImportError" />
    </MudTabPanel>

    <MudTabPanel Text="Upload Files" Icon="@Icons.Material.Filled.UploadFile">
        <FileUploadTab @bind-Importing="_importing"
                       GetTenantAssignments="GetTenantAssignments" />
    </MudTabPanel>

    <MudTabPanel Text="Database" Icon="@Icons.Material.Filled.Storage">
        <DatabaseImportTab @bind-Importing="_importing"
                           GetTenantAssignments="GetTenantAssignments"
                           OnImportSuccess="OnImportSuccess"
                           OnImportError="OnImportError" />
    </MudTabPanel>

    <MudTabPanel Text="Git Repository" Icon="@Icons.Material.Filled.Code">
        <GitRepoImportTab @bind-Importing="_importing" />
    </MudTabPanel>
</MudTabs>

@if (_lastResult is not null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudAlert Severity="Severity.Success">
            <span>Successfully imported: <strong>@_lastResult.FileName</strong></span>
            @if (_lastResult.ReplacedExisting)
            {
                <span> (replaced existing)</span>
            }
            <MudButton Variant="Variant.Text"
                       Size="Size.Small"
                       Class="ml-2"
                       Href="@($"/documents/{Uri.EscapeDataString(_lastResult.FileName)}")">
                View Document
            </MudButton>
        </MudAlert>
    </MudPaper>
}
@if (_lastError is not null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudAlert Severity="Severity.Error">
            <span>Import failed: @_lastError</span>
        </MudAlert>
    </MudPaper>
}

@code {
    private TenantSelectionPanel? _tenantPanel;
    private HashSet<Guid> _selectedTenantIds = [];
    private bool _importing;
    private IngestResultResponse? _lastResult;
    private string? _lastError;

    private List<TenantAssignment> GetTenantAssignments()
    {
        return _tenantPanel?.GetTenantAssignments() ?? new List<TenantAssignment>();
    }

    private void OnImportSuccess(IngestResultResponse? result)
    {
        _lastResult = result;
        _lastError = null;
    }

    private void OnImportError(string error)
    {
        _lastError = error;
        _lastResult = null;
    }
}
