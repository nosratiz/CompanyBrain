@page "/import"
@using CompanyBrain.Dashboard.Features.DocumentTenant.Requests
@inject KnowledgeApiClient Api
@inject ExternalTenantApiClient ExternalTenantApi
@inject DocumentTenantApiClient DocumentTenantApi
@inject ISnackbar Snackbar

<PageTitle>Import - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Import Documents</MudText>

@* Tenant Selection Section *@
<MudExpansionPanels Class="mb-4">
    <MudExpansionPanel Text="Tenant Access Settings" Icon="@Icons.Material.Filled.Business" @bind-Expanded="_tenantPanelExpanded">
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
            Select which tenants can access imported documents. Leave empty to make documents available to everyone.
        </MudText>
        
        @if (_loadingTenants)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_availableTenants.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No tenants configured. All imported documents will be available to everyone.
            </MudAlert>
        }
        else
        {
            <MudPaper Outlined="true" Class="pa-3 mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Color="Color.Info">
                        @if (_selectedTenantIds.Count == 0)
                        {
                            <span><strong>Public Documents</strong> - All tenants can access imported documents</span>
                        }
                        else
                        {
                            <span><strong>Restricted Access</strong> - Only @(_selectedTenantIds.Count) tenant(s) can access imported documents</span>
                        }
                    </MudText>
                </MudStack>
            </MudPaper>

            <MudSelect T="Guid"
                       Label="Select Tenants"
                       MultiSelection="true"
                       @bind-SelectedValues="SelectedTenantIds"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter"
                       Dense="true"
                       Class="mb-2">
                @foreach (var tenant in _availableTenants)
                {
                    <MudSelectItem T="Guid" Value="@tenant.Id">
                        @tenant.Name (@tenant.PlanName)
                    </MudSelectItem>
                }
            </MudSelect>

            @if (_selectedTenantIds.Count > 0)
            {
                <MudChipSet T="Guid" Class="mt-2">
                    @foreach (var tenantId in _selectedTenantIds)
                    {
                        var tenant = _availableTenants.FirstOrDefault(t => t.Id == tenantId);
                        if (tenant is not null)
                        {
                            <MudChip T="Guid" 
                                     Value="tenantId"
                                     Color="Color.Primary"
                                     Size="Size.Small"
                                     OnClose="() => RemoveTenant(tenantId)">
                                @tenant.Name
                            </MudChip>
                        }
                    }
                </MudChipSet>
            }
        }
    </MudExpansionPanel>
</MudExpansionPanels>

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Wiki URL" Icon="@Icons.Material.Filled.Link">
        <MudText Typo="Typo.h6" Class="mb-4">Import from Wiki URL</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Import a single wiki page by providing its URL. The page will be converted to Markdown and stored in the knowledge base.
        </MudText>
        
        <MudTextField @bind-Value="_wikiUrl"
                      Label="Wiki URL"
                      Placeholder="https://wiki.example.com/page"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-4" />
        
        <MudTextField @bind-Value="_wikiName"
                      Label="Document Name (optional)"
                      Placeholder="My Wiki Page"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      HelperText="Leave empty to auto-generate from page title"
                      Class="mb-4" />
        
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CloudDownload"
                   OnClick="ImportWikiUrl"
                   Disabled="@(string.IsNullOrWhiteSpace(_wikiUrl) || _importing)">
            @if (_importing && _activeTab == "wiki")
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Importing...</span>
            }
            else
            {
                <span>Import Wiki Page</span>
            }
        </MudButton>
    </MudTabPanel>
    
    <MudTabPanel Text="Batch Import" Icon="@Icons.Material.Filled.PlaylistAdd">
        <MudText Typo="Typo.h6" Class="mb-4">Batch Import Wiki URLs</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Import multiple wiki pages at once. Enter one URL per line.
        </MudText>
        
        <MudTextField @bind-Value="_batchUrls"
                      Label="Wiki URLs (one per line)"
                      Placeholder="https://wiki.example.com/page1&#10;https://wiki.example.com/page2&#10;https://wiki.example.com/page3"
                      Variant="Variant.Outlined"
                      Lines="8"
                      FullWidth="true"
                      Class="mb-4" />
        
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CloudDownload"
                   OnClick="ImportBatchWiki"
                   Disabled="@(string.IsNullOrWhiteSpace(_batchUrls) || _importing)">
            @if (_importing && _activeTab == "batch")
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Importing...</span>
            }
            else
            {
                <span>Import All</span>
            }
        </MudButton>
        
        @if (_batchResults is not null)
        {
            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Import Results</MudText>
            <MudSimpleTable Dense="true" Bordered="true">
                <thead>
                    <tr>
                        <th>URL</th>
                        <th>Status</th>
                        <th>File</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in _batchResults.Results)
                    {
                        <tr>
                            <td><code style="font-size: 0.85em;">@TruncateUrl(result.Url, 50)</code></td>
                            <td>
                                @if (result.Success)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">Success</MudChip>
                                }
                                else
                                {
                                    <MudTooltip Text="@result.Error">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Failed</MudChip>
                                    </MudTooltip>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(result.FileName))
                                {
                                    <MudLink Href="@($"/documents/{Uri.EscapeDataString(result.FileName)}")">@result.FileName</MudLink>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            <MudText Typo="Typo.caption" Class="mt-2">
                Total: @_batchResults.TotalDiscovered | 
                Success: @_batchResults.SuccessfullyIngested | 
                Failed: @_batchResults.Failed
            </MudText>
        }
    </MudTabPanel>
    
    <MudTabPanel Text="File Path" Icon="@Icons.Material.Filled.FolderOpen">
        <MudText Typo="Typo.h6" Class="mb-4">Import from File Path</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Import documents from a local file path. Supports various document formats including Office documents, PDFs, and plain text files.
        </MudText>
        
        <MudTextField @bind-Value="_filePath"
                      Label="File Path"
                      Placeholder="/path/to/document.docx or /path/to/folder"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      Class="mb-4" />
        
        <MudTextField @bind-Value="_filePathName"
                      Label="Document Name (optional)"
                      Placeholder="My Document"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      HelperText="Leave empty to use the file name"
                      Class="mb-4" />
        
        <MudAlert Severity="Severity.Info" Class="mb-4">
            <MudText Typo="Typo.body2">
                Supported formats: .docx, .doc, .pdf, .txt, .md, .html, .rtf
            </MudText>
        </MudAlert>
        
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Upload"
                   OnClick="ImportFilePath"
                   Disabled="@(string.IsNullOrWhiteSpace(_filePath) || _importing)">
            @if (_importing && _activeTab == "path")
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Importing...</span>
            }
            else
            {
                <span>Import from Path</span>
            }
        </MudButton>
    </MudTabPanel>
    
    <MudTabPanel Text="Upload Files" Icon="@Icons.Material.Filled.UploadFile">
        <MudText Typo="Typo.h6" Class="mb-4">Upload Documents</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Upload one or more files directly. Each file is converted to Markdown and added to the knowledge base as an MCP resource.
        </MudText>

        <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                       Accept=".md,.txt,.html,.htm,.docx,.doc,.pdf,.rtf"
                       MaximumFileCount="50"
                       FilesChanged="OnFilesSelected">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile">
                    Select Files
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>

        @if (_selectedFiles.Count > 0)
        {
            <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Selected Files (@_selectedFiles.Count)</MudText>
            <MudSimpleTable Dense="true" Bordered="true" Class="mb-4">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Size</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in _uploadItems)
                    {
                        <tr>
                            <td>@file.FileName</td>
                            <td>@FormatBytes(file.Size)</td>
                            <td>
                                @if (file.Status == UploadStatus.Pending)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">Pending</MudChip>
                                }
                                else if (file.Status == UploadStatus.Uploading)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                }
                                else if (file.Status == UploadStatus.Success)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                        Success@(file.ReplacedExisting ? " (replaced)" : "")
                                    </MudChip>
                                }
                                else
                                {
                                    <MudTooltip Text="@file.Error">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error">Failed</MudChip>
                                    </MudTooltip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>

            @if (_uploadItems.Any(i => i.Status == UploadStatus.Pending))
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CloudUpload"
                           OnClick="UploadAllFiles"
                           Disabled="_importing">
                    @if (_importing && _activeTab == "upload")
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Uploading @_uploadProgress of @_uploadItems.Count...</span>
                    }
                    else
                    {
                        <span>Upload All (@_selectedFiles.Count files)</span>
                    }
                </MudButton>
            }

            @if (_uploadComplete)
            {
                var successCount = _uploadItems.Count(i => i.Status == UploadStatus.Success);
                var failCount = _uploadItems.Count(i => i.Status == UploadStatus.Failed);
                <MudAlert Severity="@(failCount == 0 ? Severity.Success : Severity.Warning)" Class="mt-4">
                    Uploaded @successCount of @_uploadItems.Count files successfully.
                    @if (failCount > 0)
                    {
                        <span> @failCount failed.</span>
                    }
                </MudAlert>
            }
        }
    </MudTabPanel>
    
    <MudTabPanel Text="Database" Icon="@Icons.Material.Filled.Storage">
        <MudText Typo="Typo.h6" Class="mb-4">Import Database Schema</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Connect to a SQL Server, PostgreSQL, or MySQL database and import the full schema (tables, columns, relationships, stored procedures, functions, triggers, views) as a JSON knowledge document.
        </MudText>
        
        <MudSelect @bind-Value="_dbProvider"
                   Label="Database Provider"
                   Variant="Variant.Outlined"
                   FullWidth="true"
                   Class="mb-4">
            <MudSelectItem Value="@("SqlServer")">SQL Server</MudSelectItem>
            <MudSelectItem Value="@("PostgreSql")">PostgreSQL</MudSelectItem>
            <MudSelectItem Value="@("MySql")">MySQL</MudSelectItem>
        </MudSelect>
        
        <MudTextField @bind-Value="_dbConnectionString"
                      Label="Connection String"
                      Placeholder="@DatabaseConnectionPlaceholder"
                      Variant="Variant.Outlined"
                      InputType="InputType.Password"
                      Adornment="Adornment.End"
                      AdornmentIcon="@(_showConnectionString ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                      OnAdornmentClick="() => _showConnectionString = !_showConnectionString"
                      FullWidth="true"
                      Lines="@(_showConnectionString ? 3 : 1)"
                      Class="mb-4" />
        
        @if (_showConnectionString && !string.IsNullOrWhiteSpace(_dbConnectionString))
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                <code style="word-break: break-all;">@_dbConnectionString</code>
            </MudAlert>
        }
        
        <MudTextField @bind-Value="_dbSchemaName"
                      Label="Document Name"
                      Placeholder="my-database-schema"
                      Variant="Variant.Outlined"
                      FullWidth="true"
                      HelperText="Name used to store the schema in the knowledge base"
                      Class="mb-4" />
        
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">
            <MudText Typo="Typo.body2">
                The connection string is used only to read the schema and is not stored. Ensure the database user has read access to system views.
            </MudText>
        </MudAlert>
        
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Schema"
                   OnClick="ImportDatabaseSchema"
                   Disabled="@(string.IsNullOrWhiteSpace(_dbConnectionString) || string.IsNullOrWhiteSpace(_dbSchemaName) || _importing)">
            @if (_importing && _activeTab == "database")
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Reading Schema...</span>
            }
            else
            {
                <span>Import Schema</span>
            }
        </MudButton>
    </MudTabPanel>
</MudTabs>

@if (_lastResult is not null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudAlert Severity="Severity.Success">
            <span>Successfully imported: <strong>@_lastResult.FileName</strong></span>
            @if (_lastResult.ReplacedExisting)
            {
                <span> (replaced existing)</span>
            }
            <MudButton Variant="Variant.Text" 
                       Size="Size.Small" 
                       Class="ml-2"
                       Href="@($"/documents/{Uri.EscapeDataString(_lastResult.FileName)}")">
                View Document
            </MudButton>
        </MudAlert>
    </MudPaper>
}
@if (_lastError is not null)
{
    <MudPaper Class="pa-4 mt-4">
        <MudAlert Severity="Severity.Error">
            <span>Import failed: @_lastError</span>
        </MudAlert>
    </MudPaper>
}

@code {
    // ── Tenant selection ─────────────────────────────────────────────
    private bool _tenantPanelExpanded;
    private bool _loadingTenants = true;
    private List<TenantSummaryDto> _availableTenants = [];
    private HashSet<Guid> _selectedTenantIds = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        _loadingTenants = true;
        try
        {
            // Fetch tenants directly from external TenantApi
            var tenants = await ExternalTenantApi.GetTenantsAsync();
            _availableTenants = tenants.ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load tenants: {ex.Message}", Severity.Warning);
            _availableTenants = [];
        }
        finally
        {
            _loadingTenants = false;
        }
    }

    private void RemoveTenant(Guid tenantId)
    {
        _selectedTenantIds.Remove(tenantId);
    }

    private IEnumerable<Guid> SelectedTenantIds
    {
        get => _selectedTenantIds;
        set => _selectedTenantIds = value.ToHashSet();
    }

    private async Task AssignDocumentToTenantsAsync(string fileName)
    {
        if (_selectedTenantIds.Count == 0) return;

        var tenantAssignments = _selectedTenantIds
            .Select(id =>
            {
                var tenant = _availableTenants.FirstOrDefault(t => t.Id == id);
                return new TenantAssignment(id, tenant?.Name ?? "Unknown");
            })
            .ToList();

        var result = await DocumentTenantApi.UpdateDocumentTenantsAsync(fileName, tenantAssignments);
        if (result is not null)
        {
            Snackbar.Add($"Document assigned to {tenantAssignments.Count} tenant(s)", Severity.Info);
        }
    }

    // ── Wiki import ──────────────────────────────────────────────────
    private string _wikiUrl = "";
    private string _wikiName = "";
    private string _batchUrls = "";
    private string _filePath = "";
    private string _filePathName = "";
    private bool _importing;
    private string _activeTab = "";
    
    private IngestResultResponse? _lastResult;
    private string? _lastError;
    private IngestWikiBatchResponse? _batchResults;

    private async Task ImportWikiUrl()
    {
        if (string.IsNullOrWhiteSpace(_wikiUrl)) return;

        _importing = true;
        _activeTab = "wiki";
        _lastResult = null;
        _lastError = null;
        
        try
        {
            var name = string.IsNullOrWhiteSpace(_wikiName) ? null : _wikiName;
            _lastResult = await Api.IngestWikiAsync(_wikiUrl, name);
            Snackbar.Add($"Successfully imported {_lastResult?.FileName}", Severity.Success);
            
            // Assign to selected tenants
            if (_lastResult?.FileName is not null)
            {
                await AssignDocumentToTenantsAsync(_lastResult.FileName);
            }
            
            _wikiUrl = "";
            _wikiName = "";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            _lastError = ex.Message;
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task ImportBatchWiki()
    {
        if (string.IsNullOrWhiteSpace(_batchUrls)) return;

        _importing = true;
        _activeTab = "batch";
        _batchResults = null;
        _lastResult = null;
        _lastError = null;
        
        try
        {
            var urls = _batchUrls
                .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                .Select(u => u.Trim())
                .Where(u => !string.IsNullOrWhiteSpace(u))
                .ToList();

            if (!urls.Any())
            {
                Snackbar.Add("Please enter at least one URL", Severity.Warning);
                return;
            }

            // Batch import uses first URL as the base for discovering links
            _batchResults = await Api.IngestWikiBatchAsync(urls.First());
            
            if (_batchResults?.SuccessfullyIngested > 0)
            {
                Snackbar.Add($"Successfully imported {_batchResults.SuccessfullyIngested} of {_batchResults.TotalDiscovered} documents", 
                    _batchResults.Failed > 0 ? Severity.Warning : Severity.Success);
                
                // Assign successful imports to selected tenants
                if (_selectedTenantIds.Count > 0 && _batchResults.Results is not null)
                {
                    foreach (var result in _batchResults.Results.Where(r => r.Success && !string.IsNullOrEmpty(r.FileName)))
                    {
                        await AssignDocumentToTenantsAsync(result.FileName!);
                    }
                }
            }
            else
            {
                Snackbar.Add("All imports failed", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Batch import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private async Task ImportFilePath()
    {
        if (string.IsNullOrWhiteSpace(_filePath)) return;

        _importing = true;
        _activeTab = "path";
        _lastResult = null;
        _lastError = null;
        
        try
        {
            var name = string.IsNullOrWhiteSpace(_filePathName) ? null : _filePathName;
            _lastResult = await Api.IngestDocumentPathAsync(_filePath, name);
            Snackbar.Add($"Successfully imported {_lastResult?.FileName}", Severity.Success);
            
            // Assign to selected tenants
            if (_lastResult?.FileName is not null)
            {
                await AssignDocumentToTenantsAsync(_lastResult.FileName);
            }
            
            _filePath = "";
            _filePathName = "";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
            _lastError = ex.Message;
        }
        finally
        {
            _importing = false;
        }
    }

    private static string TruncateUrl(string url, int maxLength)
    {
        if (url.Length <= maxLength) return url;
        return url[..(maxLength - 3)] + "...";
    }

    // ── File upload ──────────────────────────────────────────────────

    private IReadOnlyList<IBrowserFile> _selectedFiles = [];
    private List<UploadItem> _uploadItems = [];
    private int _uploadProgress;
    private bool _uploadComplete;

    private void OnFilesSelected(IReadOnlyList<IBrowserFile>? files)
    {
        _selectedFiles = files ?? [];
        _uploadComplete = false;
        _uploadItems = _selectedFiles.Select(f => new UploadItem
        {
            FileName = f.Name,
            Size = f.Size,
        }).ToList();
    }

    private async Task UploadAllFiles()
    {
        _importing = true;
        _activeTab = "upload";
        _uploadProgress = 0;
        _uploadComplete = false;
        _lastResult = null;
        _lastError = null;

        var successfulFileNames = new List<string>();

        try
        {
            for (var i = 0; i < _selectedFiles.Count; i++)
            {
                var file = _selectedFiles[i];
                var item = _uploadItems[i];

                item.Status = UploadStatus.Uploading;
                _uploadProgress = i + 1;
                StateHasChanged();

                try
                {
                    await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
                    var result = await Api.UploadDocumentAsync(stream, file.Name);
                    item.Status = UploadStatus.Success;
                    item.ReplacedExisting = result?.ReplacedExisting ?? false;
                    
                    if (result?.FileName is not null)
                    {
                        successfulFileNames.Add(result.FileName);
                    }
                }
                catch (Exception ex)
                {
                    item.Status = UploadStatus.Failed;
                    item.Error = ex.Message;
                }
            }

            var successCount = _uploadItems.Count(i => i.Status == UploadStatus.Success);
            if (successCount > 0)
            {
                Snackbar.Add($"Successfully uploaded {successCount} of {_uploadItems.Count} files", Severity.Success);
                
                // Assign successful uploads to selected tenants
                if (_selectedTenantIds.Count > 0)
                {
                    foreach (var fileName in successfulFileNames)
                    {
                        await AssignDocumentToTenantsAsync(fileName);
                    }
                }
            }
        }
        finally
        {
            _importing = false;
            _uploadComplete = true;
        }
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes is >= 0 and <= 1023)
            return $"{bytes} B";
        if (bytes is >= 1024 and <= 1048575)
            return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private enum UploadStatus { Pending, Uploading, Success, Failed }

    private sealed class UploadItem
    {
        public string FileName { get; set; } = "";
        public long Size { get; set; }
        public UploadStatus Status { get; set; } = UploadStatus.Pending;
        public bool ReplacedExisting { get; set; }
        public string? Error { get; set; }
    }

    // ── Database schema import ───────────────────────────────────────

    private string _dbConnectionString = "";
    private string _dbSchemaName = "";
    private string _dbProvider = "SqlServer";
    private bool _showConnectionString;

    private string DatabaseConnectionPlaceholder => _dbProvider switch
    {
        "PostgreSql" => "Host=myserver;Database=mydb;Username=postgres;Password=***",
        "MySql" => "Server=myserver;Database=mydb;User=root;Password=***",
        _ => "Server=myserver;Database=mydb;User Id=sa;Password=***;TrustServerCertificate=True",
    };

    private async Task ImportDatabaseSchema()
    {
        if (string.IsNullOrWhiteSpace(_dbConnectionString) || string.IsNullOrWhiteSpace(_dbSchemaName)) return;

        _importing = true;
        _activeTab = "database";
        _lastResult = null;
        _lastError = null;

        try
        {
            _lastResult = await Api.IngestDatabaseSchemaAsync(_dbConnectionString, _dbSchemaName, _dbProvider);
            Snackbar.Add($"Successfully imported schema as {_lastResult?.FileName}", Severity.Success);
            
            // Assign to selected tenants
            if (_lastResult?.FileName is not null)
            {
                await AssignDocumentToTenantsAsync(_lastResult.FileName);
            }
            
            _dbConnectionString = "";
            _dbSchemaName = "";
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Schema import failed: {ex.Message}", Severity.Error);
            _lastError = ex.Message;
        }
        finally
        {
            _importing = false;
        }
    }
}
