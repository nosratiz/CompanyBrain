@page "/"
@inject TenantApiClient Api

<PageTitle>Dashboard - Company Brain</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_tenant is not null)
{
    <MudGrid>
        <!-- MCP Connection Status Card -->
        <MudItem xs="12" md="6" lg="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="@(_mcpConnected ? Color.Success : Color.Error)">
                            <MudIcon Icon="@Icons.Material.Filled.CloudQueue" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">MCP Connection</MudText>
                        <MudText Typo="Typo.body2" Color="@(_mcpConnected ? Color.Success : Color.Error)">
                            @(_mcpConnected ? "Connected" : "Disconnected")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-2">Server: @(_mcpInfo?.ServerUrl ?? "N/A")</MudText>
                    <MudText Typo="Typo.body2">Protocol: @(_mcpInfo?.Protocol ?? "N/A")</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/mcp-status">View Details</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Storage Usage Card -->
        <MudItem xs="12" md="6" lg="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Info">
                            <MudIcon Icon="@Icons.Material.Filled.Storage" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Storage</MudText>
                        <MudText Typo="Typo.body2">@(_storageStats?.DocumentCount ?? 0) documents</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-2">
                        @(_storageStats?.FormattedSize ?? "0 B") used
                    </MudText>
                    <div class="usage-bar">
                        <div class="usage-bar-fill @GetUsageClass(_storageStats?.UsagePercentage ?? 0)"
                             style="width: @(Math.Min(_storageStats?.UsagePercentage ?? 0, 100))%"></div>
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">
                        @((_storageStats?.UsagePercentage ?? 0).ToString("F1"))% of quota used
                    </MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/documents">Manage Documents</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- API Keys Card -->
        <MudItem xs="12" md="6" lg="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Warning">
                            <MudIcon Icon="@Icons.Material.Filled.Key" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">API Keys</MudText>
                        <MudText Typo="Typo.body2">@_tenant.ActiveApiKeys active</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">
                        @_tenant.ActiveApiKeys / @_tenant.MaxApiKeys keys used
                    </MudText>
                    <MudProgressLinear Value="@((double)_tenant.ActiveApiKeys / _tenant.MaxApiKeys * 100)"
                                       Color="Color.Warning" Class="mt-2" />
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/licenses">Manage Keys</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Plan Info Card -->
        <MudItem xs="12" md="6" lg="4">
            <MudCard>
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudAvatar Color="Color.Primary">
                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" />
                        </MudAvatar>
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Current Plan</MudText>
                        <MudChip T="string" Color="@GetPlanColor(_tenant.Plan)" Size="Size.Small">@_tenant.Plan</MudChip>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">Max Documents: @_tenant.MaxDocuments.ToString("N0")</MudText>
                    <MudText Typo="Typo.body2">Max API Keys: @_tenant.MaxApiKeys</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary">Upgrade Plan</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Quick Actions -->
    <MudText Typo="Typo.h5" Class="mt-6 mb-4">Quick Actions</MudText>
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Upload" Href="/documents">
                Upload Document
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Add" Href="/licenses">
                Create API Key
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Outlined" Color="Color.Info" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Link" Href="/mcp-status">
                Connection Setup
            </MudButton>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Help">
                Documentation
            </MudButton>
        </MudItem>
    </MudGrid>
}
else
{
    <MudAlert Severity="Severity.Warning">No tenant selected. Please select a tenant first.</MudAlert>
}

@code {
    private bool _loading = true;
    private TenantResponse? _tenant;
    private TenantStorageStatsResponse? _storageStats;
    private McpConnectionInfoResponse? _mcpInfo;
    private bool _mcpConnected = false;

    // TODO: Get from auth context or route
    private Guid _tenantId = Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var tenants = await Api.ListTenantsAsync();
            if (tenants?.Tenants.FirstOrDefault() is { } first)
            {
                _tenantId = first.Id;
                _tenant = await Api.GetTenantAsync(_tenantId);
                _storageStats = await Api.GetStorageStatsAsync(_tenantId);
                _mcpInfo = await Api.GetMcpConnectionInfoAsync(_tenantId);
                _mcpConnected = true; // TODO: Implement actual health check
            }
        }
        catch (Exception)
        {
            // Handle error
        }
        finally
        {
            _loading = false;
        }
    }

    private static string GetUsageClass(double percentage)
    {
        if (percentage < 50) return "low";
        if (percentage < 80) return "medium";
        return "high";
    }

    private static Color GetPlanColor(string plan)
    {
        return plan switch
        {
            "Free" => Color.Default,
            "Starter" => Color.Info,
            "Professional" => Color.Primary,
            "Enterprise" => Color.Secondary,
            _ => Color.Default
        };
    }
}
