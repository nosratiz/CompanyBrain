@page "/"
@inject KnowledgeApiClient Api

<PageTitle>Dashboard - Deep Root</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Knowledge Base Dashboard</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="6" lg="3">
            <StatCard Title="Documents"
                      Value="@_resources.Count.ToString()"
                      Icon="@Icons.Material.Filled.Description"
                      AvatarColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" md="6" lg="3">
            <StatCard Title="Total Size"
                      Value="@FormatHelper.FormatBytes(_resources.Sum(r => r.Size ?? 0))"
                      Icon="@Icons.Material.Filled.Storage"
                      AvatarColor="Color.Info" />
        </MudItem>

        <MudItem xs="12" md="6" lg="3">
            <StatCard Title="Markdown"
                      Value="@_resources.Count(r => r.MimeType == "text/markdown").ToString()"
                      Icon="@Icons.Material.Filled.Article"
                      AvatarColor="Color.Success" />
        </MudItem>

        <MudItem xs="12" md="6" lg="3">
            <StatCard Title="Status"
                      Value="@(_resources.Count > 0 ? "Ready" : "Empty")"
                      Icon="@Icons.Material.Filled.Update"
                      AvatarColor="Color.Warning"
                      UseBodyText="true" />
        </MudItem>

        <MudItem xs="12">
            <RecentDocumentsPanel Documents="@_resources.Take(5)">
                <EmptyMessage>
                    No documents found. <MudLink Href="/import">Import your first document</MudLink>.
                </EmptyMessage>
            </RecentDocumentsPanel>
        </MudItem>

        <MudItem xs="12">
            <QuickActionsPanel Actions="@_quickActions" />
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private List<KnowledgeResourceDescriptor> _resources = [];

    private static readonly QuickActionsPanel.QuickAction[] _quickActions =
    [
        new("Search Knowledge", "/search", Icons.Material.Filled.Search, Color.Primary),
        new("Import from Wiki", "/import", Icons.Material.Filled.Link, Color.Secondary)
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await Api.ListResourcesAsync();
            _resources = response?.ToList() ?? [];
        }
        catch
        {
            // Handle error silently
        }
        finally
        {
            _loading = false;
        }
    }
}
