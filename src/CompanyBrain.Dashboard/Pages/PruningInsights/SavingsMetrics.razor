@* Savings & efficiency metrics: donut chart, token counter, dollar savings *@

<MudPaper Class="pa-4 pruning-panel">
    <MudStack Spacing="3">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Savings" Color="Color.Success" />
            <MudText Typo="Typo.h6">Savings &amp; Efficiency</MudText>
        </MudStack>

        @if (!HasData)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Class="py-6">
                <MudIcon Icon="@Icons.Material.Filled.BarChart" Size="Size.Large"
                         Style="color: var(--mud-palette-text-disabled);" />
                <MudText Typo="Typo.body2" Style="color: var(--mud-palette-text-secondary);">
                    Metrics will appear after the first pruning operation.
                </MudText>
            </MudStack>
        }
        else
        {
            <MudGrid>
                @* Donut Chart *@
                <MudItem xs="12" md="5">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <MudChart ChartType="ChartType.Donut"
                                  InputData="@ChartData"
                                  InputLabels="@ChartLabels"
                                  Width="200px" Height="200px"
                                  ChartOptions="_chartOptions" />
                        <MudStack Row="true" Spacing="3" Justify="Justify.Center">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <div style="width:12px; height:12px; border-radius:3px; background: var(--mud-palette-primary);"></div>
                                <MudText Typo="Typo.caption">Kept Local</MudText>
                            </MudStack>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <div style="width:12px; height:12px; border-radius:3px; background: var(--mud-palette-success);"></div>
                                <MudText Typo="Typo.caption">Sent to Cloud</MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>
                </MudItem>

                @* Metric Cards *@
                <MudItem xs="12" md="7">
                    <MudGrid>
                        <MudItem xs="6">
                            <MudPaper Class="pa-3 metric-card" Elevation="0">
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    Tokens Saved
                                </MudText>
                                <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight: 700;">
                                    @FormatNumber(TokensSaved)
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Class="pa-3 metric-card" Elevation="0">
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    Est. Savings
                                </MudText>
                                <MudText Typo="Typo.h5" Color="Color.Success" Style="font-weight: 700;">
                                    $@EstimatedSavings.ToString("F4")
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Class="pa-3 metric-card" Elevation="0">
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    Tool Calls
                                </MudText>
                                <MudText Typo="Typo.h5" Style="font-weight: 700;">
                                    @TotalCalls
                                </MudText>
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="6">
                            <MudPaper Class="pa-3 metric-card" Elevation="0">
                                <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                                    Reduction
                                </MudText>
                                <MudText Typo="Typo.h5" Color="Color.Warning" Style="font-weight: 700;">
                                    @((DataKeptRatio * 100).ToString("F1"))%
                                </MudText>
                            </MudPaper>
                        </MudItem>
                    </MudGrid>
                </MudItem>
            </MudGrid>

            @* Cost breakdown *@
            <MudDivider />
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1"
                         Style="vertical-align: text-bottom;" />
                Estimated at $15.00 per 1M tokens (average Claude/GPT pricing).
                Original: @FormatNumber(OriginalTokens) tokens →
                Sent: @FormatNumber(SentTokens) tokens.
            </MudText>
        }
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public PruningStateContainer State { get; set; } = null!;

    /// <summary>
    /// When provided (loaded from DB), these events override the in-memory session state
    /// for metrics. This makes the dashboard work even when MCP calls come from a separate
    /// stdio process (e.g. Claude Desktop).
    /// </summary>
    [Parameter]
    public IReadOnlyList<PruningEvent>? Events { get; set; }

    // ── computed from DB events when available, fall back to in-memory session ──
    private bool HasData       => Events is { Count: > 0 } || State.Session.TotalCallsRecorded > 0;
    private int  TotalCalls    => Events?.Count           ?? State.Session.TotalCallsRecorded;
    private long TokensSaved   => Events != null ? Events.Sum(e => (long)e.TokensSaved)     : State.Session.CumulativeTokensSaved;
    private long OriginalTokens=> Events != null ? Events.Sum(e => (long)e.OriginalTokens)  : State.Session.CumulativeOriginalTokens;
    private long SentTokens    => Events != null ? Events.Sum(e => (long)e.PrunedTokens)    : State.Session.CumulativePrunedTokens;
    private decimal EstimatedSavings => TokensSaved * 15m / 1_000_000m;
    private double DataKeptRatio => OriginalTokens == 0 ? 0.0 : (double)TokensSaved / OriginalTokens;

    private readonly ChartOptions _chartOptions = new()
    {
        ChartPalette = ["#667eea", "#4caf50"]
    };

    private double[] ChartData =>
    [
        Math.Max(DataKeptRatio * 100, 0.1),
        Math.Max((1 - DataKeptRatio) * 100, 0.1)
    ];

    private string[] ChartLabels => ["Kept Local", "Sent to Cloud"];

    private static string FormatNumber(long value) => value switch
    {
        >= 1_000_000 => $"{value / 1_000_000.0:F1}M",
        >= 1_000 => $"{value / 1_000.0:F1}K",
        _ => value.ToString("N0")
    };
}
