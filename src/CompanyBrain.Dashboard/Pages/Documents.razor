@page "/documents"
@page "/documents/{FileName}"
@inject KnowledgeApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Documents - Company Brain</PageTitle>

@if (!string.IsNullOrEmpty(FileName))
{
    <!-- Document Detail View -->
    <div class="d-flex align-center mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/documents"))" />
        <MudText Typo="Typo.h4" Class="ml-2">@Uri.UnescapeDataString(FileName)</MudText>
    </div>

    @if (_loadingContent)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_documentContent is not null)
    {
        <MudPaper Class="pa-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_documentContent.MimeType</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_documentContent.ResourceUri</MudText>
            </div>
            <MudDivider Class="mb-4" />
            <pre style="white-space: pre-wrap; word-wrap: break-word; font-family: monospace; font-size: 0.9em;">@_documentContent.Content</pre>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Error">Document not found.</MudAlert>
    }
}
else
{
    <!-- Document List View -->
    <MudText Typo="Typo.h4" Class="mb-4">Documents</MudText>

    <MudPaper Class="pa-4">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudTextField @bind-Value="_searchQuery"
                          Placeholder="Filter documents..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Class="flex-grow-0"
                          Style="width: 300px;" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       Href="/import">
                Import Documents
            </MudButton>
        </div>

        <MudTable Items="@FilteredResources"
                  Hover="true"
                  Striped="true"
                  Loading="_loading"
                  LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Size</MudTh>
                <MudTh>Last Modified</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudLink Href="@($"/documents/{Uri.EscapeDataString(context.FileName)}")">
                        <strong>@context.FileName</strong>
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Color="@GetMimeTypeColor(context.MimeType)">
                        @GetMimeTypeLabel(context.MimeType)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Size">@FormatBytes(context.SizeBytes)</MudTd>
                <MudTd DataLabel="Last Modified">@context.LastModified.ToLocalTime().ToString("g")</MudTd>
                <MudTd DataLabel="Actions">
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                   Size="Size.Small"
                                   OnClick="@(() => ViewDocument(context.FileName))"
                                   Title="View" />
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No documents found. <MudLink Href="/import">Import your first document</MudLink>.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
}

@code {
    [Parameter] public string? FileName { get; set; }

    private bool _loading = true;
    private bool _loadingContent = false;
    private List<KnowledgeResourceDescriptor> _resources = [];
    private KnowledgeResourceContent? _documentContent;
    private string _searchQuery = "";

    private IEnumerable<KnowledgeResourceDescriptor> FilteredResources => string.IsNullOrWhiteSpace(_searchQuery)
        ? _resources.OrderByDescending(r => r.LastModified)
        : _resources
            .Where(r => r.FileName.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(r => r.LastModified);

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(FileName))
        {
            await LoadDocumentContent();
        }
        else
        {
            await LoadResources();
        }
    }

    private async Task LoadResources()
    {
        _loading = true;
        try
        {
            var response = await Api.ListResourcesAsync();
            _resources = response?.ToList() ?? [];
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load documents: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDocumentContent()
    {
        _loadingContent = true;
        try
        {
            _documentContent = await Api.GetResourceAsync(Uri.UnescapeDataString(FileName!));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load document: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingContent = false;
        }
    }

    private void ViewDocument(string fileName)
    {
        Navigation.NavigateTo($"/documents/{Uri.EscapeDataString(fileName)}");
    }

    private static string FormatBytes(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        int order = 0;
        double size = bytes;
        while (size >= 1024 && order < sizes.Length - 1)
        {
            order++;
            size /= 1024;
        }
        return $"{size:0.##} {sizes[order]}";
    }

    private static Color GetMimeTypeColor(string mimeType) => mimeType switch
    {
        "text/markdown" => Color.Primary,
        "text/plain" => Color.Default,
        "text/html" => Color.Info,
        _ => Color.Default
    };

    private static string GetMimeTypeLabel(string mimeType) => mimeType switch
    {
        "text/markdown" => "Markdown",
        "text/plain" => "Text",
        "text/html" => "HTML",
        _ => mimeType
    };
}
