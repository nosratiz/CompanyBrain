@page "/documents"
@page "/documents/{FileName}"
@inject KnowledgeApiClient Api
@inject DocumentTenantApiClient TenantApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject UnauthorizedRedirectService AuthRedirect

<PageTitle>Documents - Company Brain</PageTitle>

@if (!string.IsNullOrEmpty(FileName))
{
    <!-- Document Detail View -->
    <div class="d-flex align-center mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Navigation.NavigateTo("/documents"))" />
        <MudText Typo="Typo.h4" Class="ml-2">@Uri.UnescapeDataString(FileName)</MudText>
    </div>

    @if (_loadingContent)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else if (_documentContent is not null)
    {
        <MudPaper Class="pa-4">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudChip T="string" Size="Size.Small" Color="Color.Primary">@_documentContent.MimeType</MudChip>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@_documentContent.Uri</MudText>
            </div>
            <MudDivider Class="mb-4" />
            <pre style="white-space: pre-wrap; word-wrap: break-word; font-family: monospace; font-size: 0.9em;">@_documentContent.Content</pre>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Error">Document not found.</MudAlert>
    }
}
else
{
    <!-- Document List View -->
    <MudText Typo="Typo.h4" Class="mb-4">Documents</MudText>

    <MudPaper Class="pa-4">
        <div class="d-flex justify-space-between align-center mb-4">
            <MudTextField @bind-Value="_searchQuery"
                          Placeholder="Filter documents..."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          Class="flex-grow-0"
                          Style="width: 300px;" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.CloudUpload"
                       Href="/import">
                Import Documents
            </MudButton>
        </div>

        <MudTable Items="@FilteredResources"
                  Hover="true"
                  Striped="true"
                  Loading="_loading"
                  LoadingProgressColor="Color.Primary">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Size</MudTh>
                <MudTh>Tenant Access</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">
                    <MudLink Href="@($"/documents/{Uri.EscapeDataString(context.Name)}")">
                        <strong>@context.Name</strong>
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Type">
                    <MudChip T="string" Size="Size.Small" Color="@UiDisplayHelper.GetMimeTypeColor(context.MimeType)">
                        @UiDisplayHelper.GetMimeTypeLabel(context.MimeType)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Size">@FormatHelper.FormatBytes(context.Size ?? 0)</MudTd>
                <MudTd DataLabel="Tenant Access">
                    @{
                        var tenantCount = GetTenantCount(context.Name);
                    }
                    @if (tenantCount == 0)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.Public">
                            Everyone
                        </MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Icon="@Icons.Material.Filled.Business">
                            @tenantCount tenant@(tenantCount > 1 ? "s" : "")
                        </MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="Actions">
                    <MudTooltip Text="View">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Size="Size.Small"
                                       OnClick="@(() => ViewDocument(context.Name))" />
                    </MudTooltip>
                    <MudTooltip Text="Manage Tenant Access">
                        <MudIconButton Icon="@Icons.Material.Filled.Business"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       OnClick="@(() => OpenTenantDialogAsync(context.Name))" />
                    </MudTooltip>
                    <MudTooltip Text="Delete">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       Disabled="_deleting"
                                       OnClick="@(() => DeleteDocumentAsync(context.Name))" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText>No documents found. <MudLink Href="/import">Import your first document</MudLink>.</MudText>
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager />
            </PagerContent>
        </MudTable>
    </MudPaper>
}

@code {
    [Parameter] public string? FileName { get; set; }

    private bool _loading = true;
    private bool _loadingContent = false;
    private bool _deleting = false;
    private List<KnowledgeResourceDescriptor> _resources = [];
    private KnowledgeResourceContent? _documentContent;
    private string _searchQuery = "";
    private Dictionary<string, int> _tenantCounts = [];

    private IEnumerable<KnowledgeResourceDescriptor> FilteredResources => string.IsNullOrWhiteSpace(_searchQuery)
        ? _resources
        : _resources
            .Where(r => r.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    private int GetTenantCount(string fileName) =>
        _tenantCounts.TryGetValue(fileName, out var count) ? count : 0;

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(FileName))
        {
            await LoadDocumentContent();
        }
        else
        {
            await LoadResources();
        }
    }

    private async Task LoadResources()
    {
        _loading = true;
        try
        {
            var response = await Api.ListResourcesAsync();
            _resources = response?.ToList() ?? [];
            
            // Load tenant counts for each document
            await LoadTenantCountsAsync();
        }
        catch (Exception ex)
        {
            if (await AuthRedirect.HandleIfUnauthorized(ex)) return;
            Snackbar.Add($"Failed to load documents: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadTenantCountsAsync()
    {
        _tenantCounts.Clear();
        
        // Load tenant assignments for each document in parallel (batched for performance)
        var tasks = _resources.Select(async r =>
        {
            var actualFileName = FormatHelper.StripResourcesPrefix(r.Name);
            var assignments = await TenantApi.GetAssignmentsByDocumentAsync(actualFileName);
            return (r.Name, Count: assignments?.Tenants.Count ?? 0);
        });

        var results = await Task.WhenAll(tasks);
        foreach (var (name, count) in results)
        {
            _tenantCounts[name] = count;
        }
    }

    private async Task LoadDocumentContent()
    {
        _loadingContent = true;
        try
        {
            var rawName = Uri.UnescapeDataString(FileName!);
            var actualFileName = FormatHelper.StripResourcesPrefix(rawName);
            _documentContent = await Api.GetResourceAsync(actualFileName);
        }
        catch (Exception ex)
        {
            if (await AuthRedirect.HandleIfUnauthorized(ex)) return;
            Snackbar.Add($"Failed to load document: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingContent = false;
        }
    }

    private void ViewDocument(string name)
    {
        Navigation.NavigateTo($"/documents/{Uri.EscapeDataString(name)}");
    }

    private async Task DeleteDocumentAsync(string name)
    {
        var actualFileName = FormatHelper.StripResourcesPrefix(name);

        var confirmed = await DialogService.ShowMessageBox(
            "Delete Document",
            $"Are you sure you want to delete '{actualFileName}'? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirmed != true) return;

        _deleting = true;
        StateHasChanged();

        try
        {
            var success = await Api.DeleteResourceAsync(actualFileName);
            if (success)
            {
                Snackbar.Add($"Deleted '{actualFileName}'", Severity.Success);
                await LoadResources();
            }
            else
            {
                Snackbar.Add($"Failed to delete '{actualFileName}'", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            if (await AuthRedirect.HandleIfUnauthorized(ex)) return;
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task OpenTenantDialogAsync(string name)
    {
        var actualFileName = FormatHelper.StripResourcesPrefix(name);
        
        var parameters = new DialogParameters<TenantAssignmentDialog>
        {
            { x => x.FileName, actualFileName }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<TenantAssignmentDialog>(
            "Manage Tenant Access",
            parameters,
            options);

        var result = await dialog.Result;
        
        if (result is not null && !result.Canceled)
        {
            // Refresh tenant counts after changes
            await LoadTenantCountsAsync();
            StateHasChanged();
        }
    }
}
