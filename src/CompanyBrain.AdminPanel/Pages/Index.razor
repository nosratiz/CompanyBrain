@page "/"
@layout MainLayout

<PageTitle>Admin Dashboard - CompanyBrain</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    @* Hero Section *@
    <div class="hero-section mb-6 slide-up">
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudText Typo="Typo.h3" Style="font-weight: 700; color: white; margin-bottom: 0.5rem;">
                    Welcome back, @_userName! 👋
                </MudText>
                <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.8); max-width: 500px;">
                    Manage users, licenses, API keys, and oversee the CompanyBrain platform.
                </MudText>
            </MudItem>
            <MudItem xs="12" md="4" Style="display: flex; align-items: center; justify-content: flex-end;">
                <MudButton Variant="Variant.Filled" Href="/admin/users"
                           Style="background: rgba(255,255,255,0.2); color: white; border-radius: 12px; backdrop-filter: blur(10px);">
                    <MudIcon Icon="@Icons.Material.Filled.People" Class="mr-2" />
                    Manage Users
                </MudButton>
            </MudItem>
        </MudGrid>
    </div>

    @* Stats Grid *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card primary modern-card fade-in" style="animation-delay: 0.1s;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Total Users</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">
                            @_totalUsers
                        </MudText>
                    </div>
                    <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <MudIcon Icon="@Icons.Material.Filled.People" Style="color: #667eea;" />
                    </div>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: #9ca3af; margin-top: 0.75rem;">
                    @_activeUsers active
                </MudText>
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card secondary modern-card fade-in" style="animation-delay: 0.2s;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">API Keys</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">
                            @_totalApiKeys
                        </MudText>
                    </div>
                    <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(240, 147, 251, 0.15) 0%, rgba(245, 87, 108, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <MudIcon Icon="@Icons.Material.Filled.VpnKey" Style="color: #f093fb;" />
                    </div>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: #9ca3af; margin-top: 0.75rem;">
                    @_activeApiKeys active
                </MudText>
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card success modern-card fade-in" style="animation-delay: 0.3s;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Licenses</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">
                            @_totalLicenses
                        </MudText>
                    </div>
                    <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(17, 153, 142, 0.15) 0%, rgba(56, 239, 125, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Style="color: #11998e;" />
                    </div>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: #9ca3af; margin-top: 0.75rem;">
                    @_activeLicenses active
                </MudText>
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <div class="stat-card warning modern-card fade-in" style="animation-delay: 0.4s;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                    <div>
                        <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Inactive Users</MudText>
                        <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">
                            @(_totalUsers - _activeUsers)
                        </MudText>
                    </div>
                    <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(242, 153, 74, 0.15) 0%, rgba(242, 201, 76, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                        <MudIcon Icon="@Icons.Material.Filled.PersonOff" Style="color: #f2994a;" />
                    </div>
                </MudStack>
                <MudText Typo="Typo.caption" Style="color: #9ca3af; margin-top: 0.75rem;">
                    accounts deactivated
                </MudText>
            </div>
        </MudItem>
    </MudGrid>

    @* Recent Users & Quick Actions *@
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6 modern-card">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                        <MudIcon Icon="@Icons.Material.Filled.PeopleAlt" Class="mr-2" Style="color: #667eea;" />
                        Recent Users
                    </MudText>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/admin/users" Size="Size.Small">
                        View All
                    </MudButton>
                </MudStack>

                @if (_recentUsers.Count == 0)
                {
                    <MudText Typo="Typo.body2" Style="color: #9ca3af;">No users found.</MudText>
                }
                else
                {
                    <MudTable Items="_recentUsers" Hover="true" Elevation="0" Dense="true" Style="background: transparent;">
                        <HeaderContent>
                            <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">User</MudTh>
                            <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Registered</MudTh>
                            <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">License</MudTh>
                            <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                    <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-size: 0.7rem;">
                                        @context.FullName.FirstOrDefault().ToString().ToUpper()
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@context.FullName</MudText>
                                        <MudText Typo="Typo.caption" Style="color: #9ca3af;">@context.Email</MudText>
                                    </div>
                                </MudStack>
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">@context.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                            </MudTd>
                            <MudTd>
                                @{
                                    var license = context.Licenses.FirstOrDefault(l => l.IsActive);
                                }
                                @if (license is not null)
                                {
                                    <MudChip T="string" Size="Size.Small" Style="background: rgba(102, 126, 234, 0.1); color: #667eea;">
                                        @license.PlanName
                                    </MudChip>
                                }
                                else
                                {
                                    <MudText Typo="Typo.body2" Style="color: #9ca3af;">None</MudText>
                                }
                            </MudTd>
                            <MudTd>
                                @if (context.IsActive)
                                {
                                    <span class="status-badge active">Active</span>
                                }
                                else
                                {
                                    <span class="status-badge revoked">Inactive</span>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-6 modern-card" Style="height: 100%;">
                <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 1rem;">
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Class="mr-2" Style="color: #667eea;" />
                    Quick Actions
                </MudText>

                <MudStack Spacing="3">
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/admin/users"
                               Style="justify-content: flex-start; border-radius: 12px; padding: 1rem;">
                        <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" />
                        Manage Users
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/admin/api-keys"
                               Style="justify-content: flex-start; border-radius: 12px; padding: 1rem;">
                        <MudIcon Icon="@Icons.Material.Filled.VpnKey" Class="mr-3" />
                        Manage API Keys
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/admin/licenses"
                               Style="justify-content: flex-start; border-radius: 12px; padding: 1rem;">
                        <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Class="mr-3" />
                        Manage Licenses
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" FullWidth="true" Href="/profile"
                               Style="justify-content: flex-start; border-radius: 12px; padding: 1rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Class="mr-3" />
                        Account Settings
                    </MudButton>
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string _userName = "Admin";
    private int _totalUsers;
    private int _activeUsers;
    private int _totalApiKeys;
    private int _activeApiKeys;
    private int _totalLicenses;
    private int _activeLicenses;
    private List<AdminUserDetail> _recentUsers = [];

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        var user = await AuthState.GetUserAsync();
        if (user is not null)
        {
            _userName = user.FullName.Split(' ').FirstOrDefault() ?? user.FullName;
        }

        await LoadDashboardDataAsync();
    }

    private async Task LoadDashboardDataAsync()
    {
        try
        {
            var usersResult = await AdminService.GetAllUsersAsync(1, 10);
            _totalUsers = usersResult.TotalCount;
            _activeUsers = usersResult.Items.Count(u => u.IsActive);
            _recentUsers = usersResult.Items.OrderByDescending(u => u.CreatedAt).Take(5).ToList();

            var licensesResult = await AdminService.GetAllLicensesAsync(1, 100);
            _totalLicenses = licensesResult.TotalCount;
            _activeLicenses = licensesResult.Items.Count(l => l.IsActive);

            var apiKeysResult = await AdminService.GetAllApiKeysAsync(1, 100);
            _totalApiKeys = apiKeysResult.TotalCount;
            _activeApiKeys = apiKeysResult.Items.Count(k => !k.IsRevoked);
        }
        catch
        {
            // Handle error silently for dashboard
        }
    }
}
