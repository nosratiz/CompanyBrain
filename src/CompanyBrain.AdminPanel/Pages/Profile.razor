@page "/profile"
@layout MainLayout

<PageTitle>Profile - CompanyBrain</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-6">
    @* Header *@
    <MudText Typo="Typo.h4" Style="font-weight: 700; margin-bottom: 0.5rem;">My Profile</MudText>
    <MudText Typo="Typo.body1" Style="color: #6b7280; margin-bottom: 2rem;">
        Manage your account information and preferences
    </MudText>

    @if (_user is not null)
    {
        <MudGrid>
            @* Profile Card *@
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 text-center modern-card">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2.5rem; color: white; font-weight: 700;">
                        @_user.FullName.FirstOrDefault().ToString().ToUpper()
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">@_user.FullName</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6b7280;">@_user.Email</MudText>
                    
                    <MudDivider Class="my-4" />
                    
                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption" Style="color: #9ca3af;">Member Since</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_user.CreatedAt.ToString("MMM yyyy")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption" Style="color: #9ca3af;">Role</MudText>
                            <MudChip T="string" Size="Size.Small" Style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); color: #667eea;">
                                Admin
                            </MudChip>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Account Details *@
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-6 modern-card">
                    <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" Style="color: #667eea;" />
                        Account Details
                    </MudText>

                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_editFullName" Label="Full Name" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_editEmail" Label="Email Address" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Value="@_user.CreatedAt.ToString("MMMM dd, yyyy")" Label="Member Since" Variant="Variant.Outlined" ReadOnly="true"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField Value="@_user.Id.ToString()[..8]" Label="User ID" Variant="Variant.Outlined" ReadOnly="true"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Fingerprint" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
                        <MudButton Variant="Variant.Text" OnClick="ResetEditFields" Disabled="_isSaving">Reset</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="SaveProfileAsync" Disabled="_isSaving"
                                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                            }
                            Save Changes
                        </MudButton>
                    </MudStack>
                </MudPaper>

                @* Stats *@
                <MudPaper Class="pa-6 modern-card mt-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-2" Style="color: #667eea;" />
                        Usage Statistics
                    </MudText>

                    <MudText Typo="Typo.body2" Style="color: #6b7280;">
                        As an administrator, you can manage users, API keys, and licenses from the admin pages.
                    </MudText>
                </MudPaper>

                @* Quick Links *@
                <MudPaper Class="pa-6 modern-card mt-4">
                    <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 1rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Link" Class="mr-2" Style="color: #667eea;" />
                        Quick Links
                    </MudText>

                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" Href="/admin/users" StartIcon="@Icons.Material.Filled.People"
                                   Style="border-radius: 10px;">
                            Manage Users
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Href="/admin/api-keys" StartIcon="@Icons.Material.Filled.VpnKey"
                                   Style="border-radius: 10px;">
                            Manage API Keys
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Href="/admin/licenses" StartIcon="@Icons.Material.Filled.WorkspacePremium"
                                   Style="border-radius: 10px;">
                            Manage Licenses
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private IAuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private UserInfo? _user;
    private string? _editFullName;
    private string? _editEmail;
    private bool _isSaving;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        _user = await AuthState.GetUserAsync();
        if (_user is not null)
        {
            _editFullName = _user.FullName;
            _editEmail = _user.Email;
        }
    }

    private void ResetEditFields()
    {
        if (_user is null) return;
        _editFullName = _user.FullName;
        _editEmail = _user.Email;
    }

    private async Task SaveProfileAsync()
    {
        if (_user is null) return;
        _isSaving = true;
        try
        {
            var request = new UpdateProfileRequest(_editFullName, _editEmail);
            var updatedUser = await AuthService.UpdateProfileAsync(request);
            if (updatedUser is not null)
            {
                _user = updatedUser;
                _editFullName = updatedUser.FullName;
                _editEmail = updatedUser.Email;
                Snackbar.Add("Profile updated successfully", Severity.Success);
            }
            else
            {
                Snackbar.Add("Failed to update profile", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred while saving", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

}
