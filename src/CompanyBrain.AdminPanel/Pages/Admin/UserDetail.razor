@page "/admin/users/{UserId:guid}"
@layout MainLayout

<PageTitle>User Details - CompanyBrain Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudButton Variant="Variant.Text" Href="/admin/users" StartIcon="@Icons.Material.Filled.ArrowBack"
               Style="color: #667eea; margin-bottom: 1rem;">
        Back to Users
    </MudButton>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="border-radius: 8px;" />
    }
    else if (_user is null)
    {
        <MudPaper Class="pa-8 text-center modern-card">
            <MudIcon Icon="@Icons.Material.Filled.PersonOff" Size="Size.Large" Color="Color.Warning" />
            <MudText Typo="Typo.h5" Class="mt-4">User Not Found</MudText>
            <MudButton Variant="Variant.Filled" Href="/admin/users" Class="mt-4" Color="Color.Primary">
                Back to Users
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudGrid>
            @* Profile Card *@
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-6 text-center modern-card">
                    <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; font-size: 2.5rem; color: white; font-weight: 700;">
                        @_user.FullName.FirstOrDefault().ToString().ToUpper()
                    </div>
                    <MudText Typo="Typo.h5" Style="font-weight: 600;">@_user.FullName</MudText>
                    <MudText Typo="Typo.body2" Style="color: #6b7280;">@_user.Email</MudText>

                    <div class="mt-3">
                        @if (_user.IsActive)
                        {
                            <span class="status-badge active">Active</span>
                        }
                        else
                        {
                            <span class="status-badge revoked">Inactive</span>
                        }
                    </div>

                    <MudDivider Class="my-4" />

                    <MudStack Spacing="2">
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption" Style="color: #9ca3af;">Registered</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_user.CreatedAt.ToString("MMM dd, yyyy")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption" Style="color: #9ca3af;">Last Login</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@(_user.LastLoginAt?.ToString("MMM dd, yyyy") ?? "Never")</MudText>
                        </MudStack>
                        <MudStack Row="true" Justify="Justify.SpaceBetween">
                            <MudText Typo="Typo.caption" Style="color: #9ca3af;">Licenses</MudText>
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_user.Licenses.Count</MudText>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudStack Spacing="2">
                        @if (_user.IsActive)
                        {
                            <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Warning"
                                       OnClick="() => ConfirmStatusChange(false)"
                                       StartIcon="@Icons.Material.Filled.Block" Style="border-radius: 12px;">
                                Deactivate User
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Success"
                                       OnClick="() => ConfirmStatusChange(true)"
                                       StartIcon="@Icons.Material.Filled.CheckCircle" Style="border-radius: 12px;">
                                Activate User
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Color="Color.Error"
                                   OnClick="ConfirmDelete"
                                   StartIcon="@Icons.Material.Filled.DeleteOutline" Style="border-radius: 12px;">
                            Delete User
                        </MudButton>
                    </MudStack>
                </MudPaper>
            </MudItem>

            @* Details & Edit *@
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-6 modern-card">
                    <MudText Typo="Typo.h6" Style="font-weight: 600; margin-bottom: 1.5rem;">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Class="mr-2" Style="color: #667eea;" />
                        Edit User Details
                    </MudText>

                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_editFullName" Label="Full Name" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_editEmail" Label="Email Address" Variant="Variant.Outlined"
                                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
                        <MudButton Variant="Variant.Text" OnClick="ResetEditFields">Reset</MudButton>
                        <MudButton Variant="Variant.Filled" OnClick="SaveUserAsync" Disabled="_isSaving"
                                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
                            @if (_isSaving)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
                            }
                            Save Changes
                        </MudButton>
                    </MudStack>
                </MudPaper>

                @* Licenses Section *@
                <MudPaper Class="pa-6 modern-card mt-4">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Class="mr-2" Style="color: #667eea;" />
                            Licenses
                        </MudText>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="ShowAssignLicenseDialog"
                                   StartIcon="@Icons.Material.Filled.Add" Style="border-radius: 10px;">
                            Assign License
                        </MudButton>
                    </MudStack>

                    @if (_user.Licenses.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color: #9ca3af; text-align: center; padding: 2rem 0;">
                            No licenses assigned to this user.
                        </MudText>
                    }
                    else
                    {
                        <MudSimpleTable Hover="true" Elevation="0" Style="background: transparent;">
                            <thead>
                                <tr>
                                    <th style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Plan</th>
                                    <th style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Tier</th>
                                    <th style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Status</th>
                                    <th style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase;">Expires</th>
                                    <th style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var license in _user.Licenses)
                                {
                                    <tr>
                                        <td style="font-weight: 500;">@license.PlanName</td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Style="background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); color: #667eea;">
                                                @license.Tier
                                            </MudChip>
                                        </td>
                                        <td>
                                            @if (license.IsActive)
                                            {
                                                <span class="status-badge active">Active</span>
                                            }
                                            else
                                            {
                                                <span class="status-badge revoked">Revoked</span>
                                            }
                                        </td>
                                        <td>@(license.ExpiresAt?.ToString("MMM dd, yyyy") ?? "Never")</td>
                                        <td style="text-align: right;">
                                            @if (license.IsActive)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Size="Size.Small"
                                                               OnClick="() => ConfirmRevokeLicense(license)"
                                                               Style="color: #f5576c;" />
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@* Status Change Dialog *@
<MudDialog @bind-Visible="_showStatusDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            @(_newStatus ? "Activate" : "Deactivate") User?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to @(_newStatus ? "activate" : "deactivate") this user?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showStatusDialog = false">Cancel</MudButton>
        <MudButton OnClick="ChangeStatusAsync" Variant="Variant.Filled"
                   Color="@(_newStatus ? Color.Success : Color.Warning)">
            Confirm
        </MudButton>
    </DialogActions>
</MudDialog>

@* Delete Dialog *@
<MudDialog @bind-Visible="_showDeleteDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color: #f5576c;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
            Delete User?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to permanently delete "<strong>@_user?.FullName</strong>"? This action cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showDeleteDialog = false">Cancel</MudButton>
        <MudButton OnClick="DeleteUserAsync" Variant="Variant.Filled" Color="Color.Error">Delete</MudButton>
    </DialogActions>
</MudDialog>

@* Assign License Dialog *@
<MudDialog @bind-Visible="_showAssignDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Class="mr-2" Style="color: #667eea;" />
            Assign License
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudSelect @bind-Value="_assignTier" Label="License Tier" Variant="Variant.Outlined"
                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Star">
            <MudSelectItem Value="@("Free")">Free</MudSelectItem>
            <MudSelectItem Value="@("Starter")">Starter</MudSelectItem>
            <MudSelectItem Value="@("Professional")">Professional</MudSelectItem>
            <MudSelectItem Value="@("Enterprise")">Enterprise</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showAssignDialog = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="AssignLicenseAsync" Disabled="_isAssigning"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            @if (_isAssigning)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
            }
            Assign
        </MudButton>
    </DialogActions>
</MudDialog>

@* Revoke License Dialog *@
<MudDialog @bind-Visible="_showRevokeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color: #f5576c;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
            Revoke License?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to revoke the "<strong>@_licenseToRevoke?.PlanName</strong>" license?</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showRevokeDialog = false">Cancel</MudButton>
        <MudButton OnClick="RevokeLicenseAsync" Variant="Variant.Filled" Color="Color.Error">Revoke</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid UserId { get; set; }

    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private AdminUserDetail? _user;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isAssigning;

    private string? _editFullName;
    private string? _editEmail;

    private bool _showStatusDialog;
    private bool _showDeleteDialog;
    private bool _showAssignDialog;
    private bool _showRevokeDialog;
    private bool _newStatus;
    private string _assignTier = "Free";
    private AdminLicenseSummary? _licenseToRevoke;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadUserAsync();
    }

    private async Task LoadUserAsync()
    {
        _isLoading = true;
        try
        {
            _user = await AdminService.GetUserByIdAsync(UserId);
            if (_user is not null)
            {
                _editFullName = _user.FullName;
                _editEmail = _user.Email;
            }
        }
        catch
        {
            Snackbar.Add("Failed to load user details", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ResetEditFields()
    {
        if (_user is null) return;
        _editFullName = _user.FullName;
        _editEmail = _user.Email;
    }

    private async Task SaveUserAsync()
    {
        if (_user is null) return;
        _isSaving = true;
        try
        {
            var request = new UpdateUserRequest(_editFullName, _editEmail);
            var success = await AdminService.UpdateUserAsync(_user.Id, request);
            if (success)
            {
                Snackbar.Add("User updated successfully", Severity.Success);
                await LoadUserAsync();
            }
            else
            {
                Snackbar.Add("Failed to update user", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ConfirmStatusChange(bool newStatus)
    {
        _newStatus = newStatus;
        _showStatusDialog = true;
    }

    private void ConfirmDelete() => _showDeleteDialog = true;

    private void ShowAssignLicenseDialog()
    {
        _assignTier = "Free";
        _showAssignDialog = true;
    }

    private void ConfirmRevokeLicense(AdminLicenseSummary license)
    {
        _licenseToRevoke = license;
        _showRevokeDialog = true;
    }

    private async Task ChangeStatusAsync()
    {
        if (_user is null) return;
        var success = await AdminService.SetUserStatusAsync(_user.Id, _newStatus);
        _showStatusDialog = false;
        if (success)
        {
            Snackbar.Add($"User {(_newStatus ? "activated" : "deactivated")} successfully", Severity.Success);
            await LoadUserAsync();
        }
        else
        {
            Snackbar.Add("Failed to update user status", Severity.Error);
        }
    }

    private async Task DeleteUserAsync()
    {
        if (_user is null) return;
        var success = await AdminService.DeleteUserAsync(_user.Id);
        _showDeleteDialog = false;
        if (success)
        {
            Snackbar.Add("User deleted successfully", Severity.Success);
            Navigation.NavigateTo("/admin/users");
        }
        else
        {
            Snackbar.Add("Failed to delete user", Severity.Error);
        }
    }

    private async Task AssignLicenseAsync()
    {
        if (_user is null) return;
        _isAssigning = true;
        try
        {
            var success = await AdminService.AssignLicenseAsync(_user.Id, _assignTier);
            _showAssignDialog = false;
            if (success)
            {
                Snackbar.Add("License assigned successfully", Severity.Success);
                await LoadUserAsync();
            }
            else
            {
                Snackbar.Add("Failed to assign license", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _isAssigning = false;
        }
    }

    private async Task RevokeLicenseAsync()
    {
        if (_licenseToRevoke is null) return;
        var success = await AdminService.RevokeLicenseAsync(_licenseToRevoke.Id);
        _showRevokeDialog = false;
        if (success)
        {
            Snackbar.Add("License revoked successfully", Severity.Success);
            await LoadUserAsync();
        }
        else
        {
            Snackbar.Add("Failed to revoke license", Severity.Error);
        }
    }
}
