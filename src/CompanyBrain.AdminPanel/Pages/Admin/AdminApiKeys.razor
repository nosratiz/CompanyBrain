@page "/admin/api-keys"
@layout MainLayout

<PageTitle>Manage API Keys - CompanyBrain Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" Class="mr-2" Style="color: #667eea;" />
                API Key Management
            </MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280;">
                View and manage all API keys across users (@_totalCount total)
            </MudText>
        </div>
        <MudTextField @bind-Value="_searchText" Placeholder="Search by name, user..." Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="400" OnDebounceIntervalElapsed="OnSearchChanged"
                      Style="max-width: 300px;" />
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="border-radius: 8px;" />
    }
    else if (_apiKeys.Count == 0)
    {
        <MudPaper Class="pa-12 text-center modern-card">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(240, 147, 251, 0.15) 0%, rgba(245, 87, 108, 0.15) 100%); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Large" Style="color: #f093fb;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 600; margin-bottom: 0.5rem;">No API Keys Found</MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280; margin-bottom: 1.5rem;">
                No API keys have been created yet.
            </MudText>
        </MudPaper>
    }
    else
    {
        @* Stats Row *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4">
                <div class="stat-card primary modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Total Keys</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_totalCount</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Key" Style="color: #667eea;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="stat-card success modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Active</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_apiKeys.Count(k => !k.IsRevoked)</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(17, 153, 142, 0.15) 0%, rgba(56, 239, 125, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: #11998e;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="stat-card warning modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Revoked</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_apiKeys.Count(k => k.IsRevoked)</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(242, 153, 74, 0.15) 0%, rgba(242, 201, 76, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" Style="color: #f2994a;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
        </MudGrid>

        @* API Keys Table *@
        <MudPaper Class="modern-card" Style="overflow: hidden;">
            <MudTable Items="_filteredKeys" Hover="true" Elevation="0" Dense="false"
                      Style="background: transparent;">
                <HeaderContent>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">User</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Name</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Key</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Scope</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Created</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Last Used</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Status</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-size: 0.75rem;">
                                @(context.UserFullName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                            </MudAvatar>
                            <div>
                                <MudText Style="font-weight: 500;">@(context.UserFullName ?? "Unknown")</MudText>
                                <MudText Typo="Typo.caption" Style="color: #9ca3af;">@(context.UserEmail ?? "")</MudText>
                            </div>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Small" Style="color: #667eea;" />
                            <MudText Style="font-weight: 500;">@context.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Key">
                        <code style="background: #f3f4f6; padding: 4px 8px; border-radius: 6px; font-size: 0.85rem;">@context.KeyPrefix</code>
                    </MudTd>
                    <MudTd DataLabel="Scope">
                        <MudChip T="string" Size="Size.Small" Style="@GetScopeStyle(context.Scope)">
                            @context.Scope
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Last Used">
                        @if (context.LastUsedAt.HasValue)
                        {
                            <span>@context.LastUsedAt?.ToString("MMM dd, yyyy")</span>
                        }
                        else
                        {
                            <span style="color: #9ca3af;">Never</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsRevoked)
                        {
                            <span class="status-badge revoked">Revoked</span>
                        }
                        else if (context.ExpiresAt.HasValue && context.ExpiresAt < DateTime.UtcNow)
                        {
                            <span class="status-badge expired">Expired</span>
                        }
                        else
                        {
                            <span class="status-badge active">Active</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                       Href="@($"/admin/users/{context.UserId}")" Style="color: #667eea;" />
                        @if (!context.IsRevoked)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Size="Size.Small"
                                           OnClick="() => ConfirmRevoke(context)"
                                           Style="color: #f5576c;" />
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@* Revoke Dialog *@
<MudDialog @bind-Visible="_showRevokeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color: #f5576c;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
            Revoke API Key?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            Are you sure you want to revoke "<strong>@_keyToRevoke?.Name</strong>"
            belonging to <strong>@(_keyToRevoke?.UserFullName ?? "Unknown")</strong>?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showRevokeDialog = false">Cancel</MudButton>
        <MudButton OnClick="RevokeKeyAsync" Variant="Variant.Filled" Color="Color.Error">Revoke</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<AdminApiKeyDetail> _apiKeys = [];
    private List<AdminApiKeyDetail> _filteredKeys = [];
    private int _totalCount;
    private bool _isLoading = true;
    private bool _showRevokeDialog;
    private string? _searchText;
    private AdminApiKeyDetail? _keyToRevoke;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadApiKeysAsync();
    }

    private async Task LoadApiKeysAsync()
    {
        _isLoading = true;
        try
        {
            var result = await AdminService.GetAllApiKeysAsync(1, 100);
            _apiKeys = result.Items.ToList();
            _totalCount = result.TotalCount;
            ApplyFilter();
        }
        catch
        {
            Snackbar.Add("Failed to load API keys", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OnSearchChanged(string text)
    {
        _searchText = text;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredKeys = _apiKeys;
        }
        else
        {
            var search = _searchText.ToLowerInvariant();
            _filteredKeys = _apiKeys.Where(k =>
                k.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (k.UserFullName?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (k.UserEmail?.Contains(search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                k.Scope.Contains(search, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private void ConfirmRevoke(AdminApiKeyDetail key)
    {
        _keyToRevoke = key;
        _showRevokeDialog = true;
    }

    private async Task RevokeKeyAsync()
    {
        if (_keyToRevoke is null) return;
        var success = await AdminService.AdminRevokeApiKeyAsync(_keyToRevoke.Id);
        _showRevokeDialog = false;
        if (success)
        {
            Snackbar.Add("API key revoked successfully", Severity.Success);
            await LoadApiKeysAsync();
        }
        else
        {
            Snackbar.Add("Failed to revoke API key", Severity.Error);
        }
    }

    private static string GetScopeStyle(string scope) => scope switch
    {
        "ReadOnly" => "background: rgba(102, 126, 234, 0.1); color: #667eea;",
        "WriteDocuments" => "background: rgba(17, 153, 142, 0.1); color: #11998e;",
        "ManageResources" => "background: rgba(242, 153, 74, 0.1); color: #f2994a;",
        "Admin" => "background: rgba(245, 87, 108, 0.1); color: #f5576c;",
        _ => "background: #f3f4f6; color: #6b7280;"
    };
}
