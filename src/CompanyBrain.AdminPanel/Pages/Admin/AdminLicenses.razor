@page "/admin/licenses"
@layout MainLayout

<PageTitle>Manage Licenses - CompanyBrain Admin</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">
                <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Class="mr-2" Style="color: #667eea;" />
                License Management
            </MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280;">
                View and manage all licenses across users (@_totalCount total)
            </MudText>
        </div>
        <MudButton Variant="Variant.Filled" OnClick="ShowAssignDialog"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
            Assign License
        </MudButton>
    </MudStack>

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="border-radius: 8px;" />
    }
    else if (_licenses.Count == 0)
    {
        <MudPaper Class="pa-12 text-center modern-card">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Size="Size.Large" Style="color: #667eea;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 600; margin-bottom: 0.5rem;">No Licenses Found</MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280; margin-bottom: 1.5rem;">
                No licenses have been assigned yet.
            </MudText>
        </MudPaper>
    }
    else
    {
        @* Stats Row *@
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="4">
                <div class="stat-card primary modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Total Licenses</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_totalCount</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.Layers" Style="color: #667eea;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="stat-card success modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Active</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_licenses.Count(l => l.IsActive)</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(17, 153, 142, 0.15) 0%, rgba(56, 239, 125, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: #11998e;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
            <MudItem xs="12" sm="4">
                <div class="stat-card warning modern-card fade-in">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.body2" Style="color: #6b7280; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">Revoked</MudText>
                            <MudText Typo="Typo.h4" Style="font-weight: 700; color: #1a1a2e; margin-top: 0.25rem;">@_licenses.Count(l => !l.IsActive)</MudText>
                        </div>
                        <div style="width: 48px; height: 48px; background: linear-gradient(135deg, rgba(242, 153, 74, 0.15) 0%, rgba(242, 201, 76, 0.15) 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center;">
                            <MudIcon Icon="@Icons.Material.Filled.RemoveCircle" Style="color: #f2994a;" />
                        </div>
                    </MudStack>
                </div>
            </MudItem>
        </MudGrid>

        @* License Table *@
        <MudPaper Class="modern-card" Style="overflow: hidden;">
            <MudTable Items="_licenses" Hover="true" Elevation="0" Dense="false"
                      Style="background: transparent;">
                <HeaderContent>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">User</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Plan</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Tier</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Purchased</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Expires</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Status</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="User">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Size="Size.Small" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-size: 0.75rem;">
                                @(context.UserFullName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                            </MudAvatar>
                            <div>
                                <MudText Style="font-weight: 500;">@(context.UserFullName ?? "Unknown")</MudText>
                                <MudText Typo="Typo.caption" Style="color: #9ca3af;">@(context.UserEmail ?? "")</MudText>
                            </div>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Plan">
                        <MudText Style="font-weight: 500;">@context.PlanName</MudText>
                    </MudTd>
                    <MudTd DataLabel="Tier">
                        <MudChip T="string" Size="Size.Small" Style="@GetTierStyle(context.Tier)">
                            @context.Tier
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Purchased">@context.PurchasedAt.ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Expires">@(context.ExpiresAt?.ToString("MMM dd, yyyy") ?? "Never")</MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsActive)
                        {
                            <span class="status-badge active">Active</span>
                        }
                        else
                        {
                            <span class="status-badge revoked">Revoked</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                                       Href="@($"/admin/users/{context.UserId}")" Style="color: #667eea;" />
                        @if (context.IsActive)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline" Size="Size.Small"
                                           OnClick="() => ConfirmRevoke(context)"
                                           Style="color: #f5576c;" />
                        }
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 10, 20, 50 }" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@* Assign License Dialog *@
<MudDialog @bind-Visible="_showAssignDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.WorkspacePremium" Class="mr-2" Style="color: #667eea;" />
            Assign License to User
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_assignUserId" Label="User ID" Variant="Variant.Outlined"
                          Placeholder="Enter user GUID"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
            <MudSelect @bind-Value="_assignTier" Label="License Tier" Variant="Variant.Outlined"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Star">
                <MudSelectItem Value="@("Free")">Free</MudSelectItem>
                <MudSelectItem Value="@("Starter")">Starter</MudSelectItem>
                <MudSelectItem Value="@("Professional")">Professional</MudSelectItem>
                <MudSelectItem Value="@("Enterprise")">Enterprise</MudSelectItem>
            </MudSelect>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showAssignDialog = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" OnClick="AssignLicenseAsync"
                   Disabled="_isAssigning || string.IsNullOrWhiteSpace(_assignUserId)"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            @if (_isAssigning)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
            }
            Assign License
        </MudButton>
    </DialogActions>
</MudDialog>

@* Revoke Dialog *@
<MudDialog @bind-Visible="_showRevokeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color: #f5576c;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
            Revoke License?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            Are you sure you want to revoke "<strong>@_licenseToRevoke?.PlanName</strong>"
            for <strong>@(_licenseToRevoke?.UserFullName ?? "Unknown")</strong>?
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showRevokeDialog = false">Cancel</MudButton>
        <MudButton OnClick="RevokeLicenseAsync" Variant="Variant.Filled" Color="Color.Error">Revoke</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IAdminService AdminService { get; set; } = default!;
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private List<AdminLicenseDetail> _licenses = [];
    private int _totalCount;
    private bool _isLoading = true;
    private bool _showAssignDialog;
    private bool _showRevokeDialog;
    private bool _isAssigning;
    private string? _assignUserId;
    private string _assignTier = "Free";
    private AdminLicenseDetail? _licenseToRevoke;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadLicensesAsync();
    }

    private async Task LoadLicensesAsync()
    {
        _isLoading = true;
        try
        {
            var result = await AdminService.GetAllLicensesAsync(1, 100);
            _licenses = result.Items.ToList();
            _totalCount = result.TotalCount;
        }
        catch
        {
            Snackbar.Add("Failed to load licenses", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowAssignDialog()
    {
        _assignUserId = null;
        _assignTier = "Free";
        _showAssignDialog = true;
    }

    private void ConfirmRevoke(AdminLicenseDetail license)
    {
        _licenseToRevoke = license;
        _showRevokeDialog = true;
    }

    private async Task AssignLicenseAsync()
    {
        if (string.IsNullOrWhiteSpace(_assignUserId) || !Guid.TryParse(_assignUserId, out var userId)) 
        {
            Snackbar.Add("Please enter a valid User ID", Severity.Warning);
            return;
        }

        _isAssigning = true;
        try
        {
            var success = await AdminService.AssignLicenseAsync(userId, _assignTier);
            _showAssignDialog = false;
            if (success)
            {
                Snackbar.Add("License assigned successfully", Severity.Success);
                await LoadLicensesAsync();
            }
            else
            {
                Snackbar.Add("Failed to assign license", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _isAssigning = false;
        }
    }

    private async Task RevokeLicenseAsync()
    {
        if (_licenseToRevoke is null) return;
        var success = await AdminService.RevokeLicenseAsync(_licenseToRevoke.Id);
        _showRevokeDialog = false;
        if (success)
        {
            Snackbar.Add("License revoked successfully", Severity.Success);
            await LoadLicensesAsync();
        }
        else
        {
            Snackbar.Add("Failed to revoke license", Severity.Error);
        }
    }

    private static string GetTierStyle(string tier) => tier switch
    {
        "Enterprise" => "background: linear-gradient(135deg, rgba(242, 153, 74, 0.15) 0%, rgba(242, 201, 76, 0.15) 100%); color: #f2994a;",
        "Professional" => "background: linear-gradient(135deg, rgba(102, 126, 234, 0.15) 0%, rgba(118, 75, 162, 0.15) 100%); color: #667eea;",
        "Starter" => "background: linear-gradient(135deg, rgba(17, 153, 142, 0.15) 0%, rgba(56, 239, 125, 0.15) 100%); color: #11998e;",
        _ => "background: #f3f4f6; color: #6b7280;"
    };
}
