@page "/api-keys"
@layout MainLayout

<PageTitle>API Keys - CompanyBrain</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
    @* Header *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-6">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 700;">API Keys</MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280;">Create and manage your API keys for MCP access</MudText>
        </div>
        <MudButton Variant="Variant.Filled" OnClick="ShowCreateDialog" Disabled="!CanCreateMoreKeys"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
            Create API Key
        </MudButton>
    </MudStack>

    @if (!CanCreateMoreKeys && _activeLicense is not null)
    {
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4" Style="border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <span>You've reached your API key limit (@_activeLicense.MaxApiKeys keys). Upgrade your plan to create more.</span>
                <MudButton Variant="Variant.Text" Color="Color.Warning" Href="/licenses" Size="Size.Small">
                    Upgrade Now
                </MudButton>
            </MudStack>
        </MudAlert>
    }

    @if (_isLoading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="border-radius: 8px;" />
    }
    else if (_apiKeys.Count == 0)
    {
        <MudPaper Class="pa-12 text-center modern-card">
            <div style="width: 80px; height: 80px; background: linear-gradient(135deg, rgba(240, 147, 251, 0.15) 0%, rgba(245, 87, 108, 0.15) 100%); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem;">
                <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Large" Style="color: #f093fb;" />
            </div>
            <MudText Typo="Typo.h5" Style="font-weight: 600; margin-bottom: 0.5rem;">No API Keys Yet</MudText>
            <MudText Typo="Typo.body1" Style="color: #6b7280; margin-bottom: 1.5rem; max-width: 400px; margin-left: auto; margin-right: auto;">
                Create your first API key to authenticate with the CompanyBrain MCP server.
            </MudText>
            <MudButton Variant="Variant.Filled" OnClick="ShowCreateDialog"
                       Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
                <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" />
                Create Your First Key
            </MudButton>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="modern-card" Style="overflow: hidden;">
            <MudTable Items="_apiKeys" Hover="true" Elevation="0" Dense="false" 
                      Style="background: transparent;">
                <HeaderContent>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Name</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Key</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Scope</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Created</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Last Used</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Status</MudTh>
                    <MudTh Style="font-weight: 600; color: #6b7280; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px; text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Small" Style="color: #667eea;" />
                            <MudText Style="font-weight: 500;">@context.Name</MudText>
                        </MudStack>
                    </MudTd>
                    <MudTd DataLabel="Key">
                        <code style="background: #f3f4f6; padding: 4px 8px; border-radius: 6px; font-size: 0.85rem;">@context.KeyPrefix***</code>
                    </MudTd>
                    <MudTd DataLabel="Scope">
                        <MudChip T="string" Size="Size.Small" Style="@GetScopeStyle(context.Scope)">
                            @context.Scope
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created">@context.CreatedAt.ToString("MMM dd, yyyy")</MudTd>
                    <MudTd DataLabel="Last Used">
                        @if (context.LastUsedAt.HasValue)
                        {
                            <span>@context.LastUsedAt?.ToString("MMM dd, yyyy")</span>
                        }
                        else
                        {
                            <span style="color: #9ca3af;">Never</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Status">
                        @if (context.IsRevoked)
                        {
                            <span class="status-badge revoked">Revoked</span>
                        }
                        else if (context.ExpiresAt.HasValue && context.ExpiresAt < DateTime.UtcNow)
                        {
                            <span class="status-badge expired">Expired</span>
                        }
                        else
                        {
                            <span class="status-badge active">Active</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        @if (!context.IsRevoked)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Size="Size.Small"
                                           OnClick="() => ConfirmRevoke(context)"
                                           Style="color: #f5576c;" />
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }
</MudContainer>

@* Create Dialog *@
<MudDialog @bind-Visible="_showCreateDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="font-weight: 600;">
            <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-2" Style="color: #667eea;" />
            Create New API Key
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudTextField @bind-Value="_newKeyName" Label="Key Name" Variant="Variant.Outlined"
                          Placeholder="e.g., Production Server, Development"
                          HelperText="A descriptive name to identify this key"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Label" />

            <MudSelect @bind-Value="_newKeyScope" Label="Permission Scope" Variant="Variant.Outlined"
                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Security">
                <MudSelectItem Value="@("ReadOnly")">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Class="mr-2" />
                        Read Only - View documents only
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="@("WriteDocuments")">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-2" />
                        Write Documents - Create and update docs
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="@("ManageResources")">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Class="mr-2" />
                        Manage Resources - Full resource access
                    </MudStack>
                </MudSelectItem>
                <MudSelectItem Value="@("Admin")">
                    <MudStack Row="true" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" Size="Size.Small" Class="mr-2" />
                        Admin - Full administrative access
                    </MudStack>
                </MudSelectItem>
            </MudSelect>

            <MudDatePicker @bind-Date="_newKeyExpiry" Label="Expiration Date (Optional)" Variant="Variant.Outlined"
                           MinDate="DateTime.Today.AddDays(1)" Placeholder="Never expires"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CalendarMonth" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showCreateDialog = false" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="CreateKeyAsync" Variant="Variant.Filled"
                   Disabled="_isCreating || string.IsNullOrWhiteSpace(_newKeyName)"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            @if (_isCreating)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="mr-2" />
            }
            Create Key
        </MudButton>
    </DialogActions>
</MudDialog>

@* Key Created Dialog *@
<MudDialog @bind-Visible="_showKeyCreatedDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = false }">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color: #11998e;" Class="mr-2" />
            <MudText Typo="Typo.h6" Style="font-weight: 600;">API Key Created!</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-4" Style="border-radius: 12px;">
            <strong>Important:</strong> This is the only time you'll see this key. Copy it now and store it securely.
        </MudAlert>
        
        <div class="api-key-display" style="position: relative;">
            <code style="word-break: break-all;">@_createdKeyPlainText</code>
            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Size="Size.Small"
                           Style="position: absolute; top: 8px; right: 8px; color: #00ff88;"
                           OnClick="CopyKeyToClipboard" />
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showKeyCreatedDialog = false" Variant="Variant.Filled"
                   Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
            <MudIcon Icon="@Icons.Material.Filled.Check" Class="mr-2" />
            I've Copied the Key
        </MudButton>
    </DialogActions>
</MudDialog>

@* Revoke Confirmation *@
<MudDialog @bind-Visible="_showRevokeDialog" Options="new DialogOptions { MaxWidth = MaxWidth.ExtraSmall }">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color: #f5576c;">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
            Revoke API Key?
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>Are you sure you want to revoke "<strong>@_keyToRevoke?.Name</strong>"? This action cannot be undone.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showRevokeDialog = false">Cancel</MudButton>
        <MudButton OnClick="RevokeKeyAsync" Variant="Variant.Filled" Color="Color.Error">
            Revoke Key
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] private IApiKeyService ApiKeyService { get; set; } = default!;
    [Inject] private ILicenseService LicenseService { get; set; } = default!;
    [Inject] private AuthStateProvider AuthState { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private List<UserApiKey> _apiKeys = [];
    private UserLicense? _activeLicense;
    private bool _isLoading = true;
    private bool _showCreateDialog = false;
    private bool _showKeyCreatedDialog = false;
    private bool _showRevokeDialog = false;
    private bool _isCreating = false;

    private string _newKeyName = "";
    private string _newKeyScope = "ReadOnly";
    private DateTime? _newKeyExpiry;
    private string? _createdKeyPlainText;
    private UserApiKey? _keyToRevoke;

    private bool CanCreateMoreKeys =>
        _activeLicense is not null && _apiKeys.Count(k => !k.IsRevoked) < _activeLicense.MaxApiKeys;

    protected override async Task OnInitializedAsync()
    {
        if (!await AuthState.IsAuthenticatedAsync())
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _isLoading = true;
        try
        {
            var licenses = await LicenseService.GetMyLicensesAsync();
            _activeLicense = licenses.FirstOrDefault(l => l.IsActive);
            _apiKeys = (await ApiKeyService.GetMyApiKeysAsync()).ToList();
        }
        catch
        {
            Snackbar.Add("Failed to load data", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowCreateDialog()
    {
        _newKeyName = "";
        _newKeyScope = "ReadOnly";
        _newKeyExpiry = null;
        _showCreateDialog = true;
    }

    private async Task CreateKeyAsync()
    {
        _isCreating = true;
        try
        {
            var request = new CreateApiKeyRequest(_newKeyName, _newKeyScope, _newKeyExpiry);
            var result = await ApiKeyService.CreateApiKeyAsync(request);

            if (result is not null)
            {
                _createdKeyPlainText = result.PlainKey;
                _showCreateDialog = false;
                _showKeyCreatedDialog = true;
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to create API key", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _isCreating = false;
        }
    }

    private void ConfirmRevoke(UserApiKey key)
    {
        _keyToRevoke = key;
        _showRevokeDialog = true;
    }

    private async Task RevokeKeyAsync()
    {
        if (_keyToRevoke is null) return;

        try
        {
            var success = await ApiKeyService.RevokeApiKeyAsync(_keyToRevoke.Id);
            if (success)
            {
                Snackbar.Add("API key revoked successfully", Severity.Success);
                await LoadDataAsync();
            }
            else
            {
                Snackbar.Add("Failed to revoke API key", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred", Severity.Error);
        }
        finally
        {
            _showRevokeDialog = false;
            _keyToRevoke = null;
        }
    }

    private async Task CopyKeyToClipboard()
    {
        if (_createdKeyPlainText is not null)
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _createdKeyPlainText);
            Snackbar.Add("API key copied to clipboard!", Severity.Success);
        }
    }

    private static string GetScopeStyle(string scope) => scope switch
    {
        "ReadOnly" => "background: rgba(102, 126, 234, 0.1); color: #667eea;",
        "WriteDocuments" => "background: rgba(17, 153, 142, 0.1); color: #11998e;",
        "ManageResources" => "background: rgba(242, 153, 74, 0.1); color: #f2994a;",
        "Admin" => "background: rgba(245, 87, 108, 0.1); color: #f5576c;",
        _ => "background: #f3f4f6; color: #6b7280;"
    };
}
